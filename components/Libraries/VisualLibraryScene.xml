<?xml version="1.0" encoding="utf-8"?>
<component name="VisualLibraryScene" extends="JFScreen">
  <children>
    <poster id="libraryBackdropFull" loadDisplayMode="scaleToZoom" width="1920" height="1080" opacity="0" />
    <poster id="libraryBackdropFullTransition" loadDisplayMode="scaleToZoom" width="1920" height="1080" opacity="0" />
    <Animation id="libraryBackdropSwapAnimation" duration="1" repeat="false" easeFunction="linear">
      <FloatFieldInterpolator key="[0.0, 1.0]" keyValue="[ 0.00, 0.25 ]" fieldToInterp="libraryBackdropFullTransition.opacity" />
      <FloatFieldInterpolator key="[0.0, 1.0]" keyValue="[ 0.25, 0.00 ]" fieldToInterp="libraryBackdropFull.opacity" />
    </Animation>

    <maskGroup translation="[820, 115]" id="backgroundMask" maskUri="pkg:/images/backgroundmask.png" maskSize="[1220,700]">
      <poster id="backdrop" loadDisplayMode="scaleToZoom" width="1100" height="700" opacity="1" />
      <poster id="backdropTransition" loadDisplayMode="scaleToZoom" width="1100" height="700" opacity="1" />
    </maskGroup>


    <Group id="contentGroup" translation="[0, 160]" clippingRect="[-100, 0, 2020, 920]">
      <MarkupGrid
        id="itemGrid"
        itemComponentName="GridItemSmall"
        vertFocusAnimationStyle="floatingFocus"
        translation="[100, 0]"
        clippingRect="[-100, -100, 1920, 1080]"
        itemSpacing="[20, 60]"
        drawFocusFeedback="false" />

      <RowList
        id="genrelist"
        itemComponentName="GridItemSmall"
        vertFocusAnimationStyle="fixed"
        rowFocusAnimationStyle="fixedFocusWrap"
        showRowLabel="true"
        rowLabelOffset="[[0, 10]]"
        itemSpacing="[20, 140]"
        translation="[100, 10]"
        drawFocusFeedback="false" />

      <RowList
        id="taglist"
        itemComponentName="GridItemSmall"
        vertFocusAnimationStyle="fixed"
        rowFocusAnimationStyle="fixedFocusWrap"
        showRowLabel="true"
        rowLabelOffset="[[0, 10]]"
        itemSpacing="[20, 140]"
        translation="[100, 10]"
        drawFocusFeedback="false" />
    </Group>

    <!-- Right-side icon sidebar (Emby style); Y ~ vertically centered for 6×52px tiles + gaps -->
    <!-- Audio Selector with Dropdown - Positioned at right sidebar area -->
    <LayoutGroup layoutDirection="horiz" id="audioSelectorGroup" translation="[1850, 376]" itemSpacings="[22]">
      <Text id="audioLabel" font="font:LargeSystemFont" width="120" height="48" vertAlign="center" horizAlign="left" color="#FFFFFF">Audio</Text>
    </LayoutGroup>

    <!-- Dropdown Popup Menu (Overlay with z-order for floating effect) -->
    <Alpha id="dropdownPopupAlpha" wrap="false" />
    
    <!-- Background rectangle for dropdown menu - dark solid, darker than page bg -->
    <Rectangle id="dropdownMenuBackground" clipToViewfinder="false">
      <FloatFieldInterpolator fieldToInterp="opacity" key="[0.0, 1.0]" keyValue="[0, 0.95]" />
    </Rectangle>

    <!-- Subtle rounded corners - Rectangle with slightly transparent border -->
    <Poster id="dropdownMenuBorder" uri="" clipToViewfinder="false">
      <FloatFieldInterpolator fieldToInterp="borderWidth" key="[0.0, 1.0]" keyValue="[0, 2]" />
    </Poster>

    <Group id="rightIcons" translation="[1840, 376]" opacity="1">
      <!-- LabelList for audio dropdown options - positioned absolutely with z-order -->
      <LabelList id="dropdownLabelList" visible="false" clipToViewfinder="false" itemSize="[200, 40]" numRows="1">
        <!-- Items will be populated dynamically - LabelList handles scrolling internally -->
        <!-- Clip the 4th entry at bottom by setting proper height -->
        <FloatFieldInterpolator fieldToInterp="height" key="[0.0, 0.4]" keyValue="[0, 1]">
          <FloatFieldInterpolator fieldToInterp="height" key="[0.0, 1.0]" keyValue="[0, 150]" />
        </FloatFieldInterpolator>
      </LabelList>

       <LayoutGroup layoutDirection="vert" itemSpacings="[4]">
        <LibrarySideIcon id="voiceBoxButton" iconUri="pkg:/images/icons/search-light.png" />
        <LibrarySideIcon id="sortButton" iconUri="pkg:/images/icons/options.png" />
        <LibrarySideIcon id="sortOrderButton" iconUri="pkg:/images/icons/up_white.png" />
        <LibrarySideIcon id="filterButton" iconUri="pkg:/images/icons/dotDotDot.png" />
        <LibrarySideIcon id="viewButton" iconUri="pkg:/images/icons/numberList.png" />
        <LibrarySideIcon id="librarySettingsButton" iconUri="pkg:/images/icons/settings.png" />
       </LayoutGroup>
     </Group>

    <Animation id="toggleDropdownOptionsAnimation" duration="0.01" repeat="false" easeFunction="linear">
      <FloatFieldInterpolator id="dropdownOptionsFade" key="[0.0, 1.0]" keyValue="[1.00, 1.00]" fieldToInterp="rightIcons.opacity" />
      <Vector2DFieldInterpolator id="dropdownOptionsMove" key="[0.1, .9]" keyValue="[[1840, 376], [1840, 376]]" fieldToInterp="rightIcons.translation" />
      <Vector2DFieldInterpolator id="itemGridMove" key="[0.1, .9]" keyValue="[[100, 0], [100, 0]]" fieldToInterp="itemGrid.translation" />
      <Vector2DFieldInterpolator id="genreListMove" key="[0.1, .9]" keyValue="[[100, 0], [100, 0]]" fieldToInterp="genrelist.translation" />
      <Vector2DFieldInterpolator id="tagListMove" key="[0.1, .9]" keyValue="[[100, 0], [100, 0]]" fieldToInterp="taglist.translation" />
    </Animation>

    <Text id="selectedItemName" visible="false" translation="[120, 115]" wrap="true" font="font:LargeBoldSystemFont" width="850" height="196" horizAlign="left" vertAlign="center" />
    <Poster id="itemLogo" visible="false" translation="[120, 115]" loadDisplayMode="scaleToFit" width="384" height="196" />

    <LayoutGroup layoutDirection="horiz" translation="[120, 320]" itemSpacings="[30]" id="infoGroup">
      <Text id="selectedItemProductionYear" font="font:SmallestSystemFont" />
      <Text id="runtime" font="font:SmallestSystemFont" />
      <Text id="selectedItemOfficialRating" font="font:SmallestSystemFont" />

      <LayoutGroup id="communityRatingGroup" visible="false" layoutDirection="horiz" itemSpacings="[-5]">
        <Poster id="star" uri="pkg:/images/sharp_star_white_18dp.png" height="28" width="28" blendColor="#00a4dcFF" />
        <Text id="communityRating" font="font:SmallestSystemFont" />
      </LayoutGroup>

      <LayoutGroup layoutDirection="horiz" id="criticRatingGroup">
        <Poster id="criticRatingIcon" height="28" width="28" />
        <Text id="criticRatingLabel" font="font:SmallestSystemFont" />
      </LayoutGroup>
    </LayoutGroup>

    <Group id="overviewGroup" translation="[120, 370]" focusable="true">
      <Rectangle id="overviewFocus" width="920" height="160" color="#01A4DC" opacity="0" translation="[-10, -10]" />
      <Text id="selectedItemOverview" font="font:SmallestSystemFont" wrap="true" lineSpacing="10" maxLines="4" width="900" ellipsisText="..." />
    </Group>

    <Text translation="[0,540]" id="emptyText" font="font:LargeSystemFont" width="1910" horizAlign="center" vertAlign="center" height="64" visible="false" />
    <Animation id="backroundSwapAnimation" duration="1" repeat="false" easeFunction="linear">
      <FloatFieldInterpolator id="fadeinLoading" key="[0.0, 1.0]" keyValue="[ 0.00, 1.00 ]" fieldToInterp="backdropTransition.opacity" />
      <FloatFieldInterpolator id="fadeoutLoaded" key="[0.0, 1.0]" keyValue="[ 1.00, 0.00 ]" fieldToInterp="backdrop.opacity" />
    </Animation>

    <Alpha id="alpha" wrap="false" />
    <!-- Solid background for the top navigation bar area (Drawn last to be on top) -->
    <Rectangle id="topBarBackground" width="1920" height="115" color="#020B2A" translation="[0, 0]" />

    <!-- Top Bar Container -->
    <Group id="topBar" translation="[0, 45]">
      <Poster id="leftArrow" uri="pkg:/images/icons/left_white.png" width="30" height="30" translation="[13, 15]" visible="false" opacity="0.5" />
      <Group id="tabsClip" translation="[48, 0]" clippingRect="[0, -20, 1420, 120]">
        <MarkupGrid
          id="categoryTabs"
          translation="[0, 0]"
          itemComponentName="TextButtonRowItem"
          numRows="1"
          numColumns="9"
          itemSpacing="[20, 0]"
          drawFocusFeedback="false"
          horizFocusAnimationStyle="floatingFocus"
          itemSize="[220, 60]" />
      </Group>
      <Poster id="rightArrow" uri="pkg:/images/icons/right_white.png" width="30" height="30" translation="[1518, 15]" visible="false" opacity="0.5" />

      <Group id="utilityGroup" translation="[1560, -2]">
        <!-- userName removed per user request -->
        <TextButton id="searchButton" iconSide="left" icon="pkg:/images/icons/search-light.png" focusIcon="pkg:/images/icons/search-light.png" text="" translation="[0, 6]" height="48" width="48" padding="8" background="#00000000" enableBorder="false" />
        <TextButton id="settingsButton" iconSide="left" icon="pkg:/images/icons/settings.png" focusIcon="pkg:/images/icons/settings.png" text="" translation="[54, 6]" height="48" width="48" padding="8" background="#00000000" enableBorder="false" />
        <Clock id="homeClock" translation="[110, 0]" />
      </Group>
    </Group>

    <Text id="tagTitle" font="font:LargeBoldSystemFont" color="#FFFFFF" translation="[100, 45]" visible="false" />

    <!-- Top Bar Separator Line -->
    <Rectangle id="topBarSeparator" translation="[0, 115]" width="1920" height="1" color="#FFFFFF" opacity="0.35" />

    <FilterPanel
      id="filterPanel"
      visible="false"
      translation="[0, 0]" />

    <BusySpinner id="loadingSpinner" translation="[960, 470]" visible="false" />
    <Text id="loadingStatusText" translation="[0, 540]" font="font:LargeBoldSystemFont" color="#FFFFFF" text="" visible="false" horizAlign="center" width="1920" />
  </children>
  <interface>
    <function name="getItemFocused" />
    <function name="redrawItems" />
    <field id="mediaType" type="string" />
    <field id="parentItem" type="node" onChange="loadInitialItems" />
    <field id="selectedItem" type="node" alwaysNotify="true" />
    <field id="quickPlayNode" type="node" alwaysNotify="true" />
    <field id="imageDisplayMode" type="string" value="" />
    <field id="alphaSelected" type="string" alias="alpha.letterSelected" onChange="alphaSelectedChanged" alwaysNotify="true" />
    <field id="searchTerm" type="string" onChange="onSearchTermChanged" alwaysNotify="true" />
    <field id="alphaActive" type="boolean" value="false" />
    <field id="showItemTitles" type="string" value="" />
    
  </interface>

</component>