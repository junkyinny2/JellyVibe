const ASPECT_RATIO_PORTRAIT_NO_TITLE = 1.52173
const ASPECT_RATIO_LANDSCAPE_NO_TITLE = .56307
const ASPECT_RATIO_PORTRAIT_WITH_TITLE = 2.217
const ASPECT_RATIO_LANDSCAPE_WITH_TITLE = 0.945

function isFullBleedLibraryView() as boolean
    return inArray(["grid", "Episodes", "Genres", "Tags", "TagDetails"], m.view)
end function

function useFullBleedLibraryBackdrop() as boolean
    return isFullBleedLibraryView() and libraryFocusBackdropEnabled()
end function

sub setupNodes()
    m.top.imageDisplayMode = "scaleToZoom"
    m.top.showItemTitles = "showalways"

    m.toggleDropdownOptionsAnimation = m.top.findNode("toggleDropdownOptionsAnimation")
    m.dropdownOptionsMove = m.top.findNode("dropdownOptionsMove")
    m.itemGridMove = m.top.findNode("itemGridMove")
    m.overviewFocus = m.top.findNode("overviewFocus")
    m.overviewGroup = m.top.findNode("overviewGroup")
    m.genreListMove = m.top.findNode("genreListMove")
    m.dropdownOptionsFade = m.top.findNode("dropdownOptionsFade")
    m.options = m.top.findNode("options")
    m.itemGrid = m.top.findNode("itemGrid")
    m.backdrop = m.top.findNode("backdrop")
    m.newBackdrop = m.top.findNode("backdropTransition")
    m.emptyText = m.top.findNode("emptyText")
    m.selectedItemName = m.top.findNode("selectedItemName")
    m.selectedItemOverview = m.top.findNode("selectedItemOverview")
    m.selectedItemProductionYear = m.top.findNode("selectedItemProductionYear")
    m.selectedItemOfficialRating = m.top.findNode("selectedItemOfficialRating")
    m.itemLogo = m.top.findNode("itemLogo")
    m.swapAnimation = m.top.findNode("backroundSwapAnimation")
    m.libraryBackdropFull = m.top.findNode("libraryBackdropFull")
    m.libraryBackdropFullTransition = m.top.findNode("libraryBackdropFullTransition")
    m.libraryBackdropSwapAnimation = m.top.findNode("libraryBackdropSwapAnimation")
    m.libraryBackdropSwapAnimation.observeField("state", "swapFullBleedDone")
    m.libraryBackdropFullTransition.observeField("loadStatus", "newFullBleedBGLoaded")
    m.alpha = m.top.findNode("alpha")
    m.alphaMenu = m.alpha.findNode("alphaMenu")
    m.communityRatingGroup = m.top.findNode("communityRatingGroup")
    m.criticRatingIcon = m.top.findNode("criticRatingIcon")
    m.criticRatingGroup = m.top.findNode("criticRatingGroup")
    m.overhang = m.top.getScene().findNode("overhang")
    m.genreList = m.top.findNode("genrelist")
    m.tagList = m.top.findNode("taglist")
    m.infoGroup = m.top.findNode("infoGroup")
    m.star = m.top.findNode("star")
    m.categoryTabs = m.top.findNode("categoryTabs")
    m.topBar = m.top.findNode("topBar")
    m.rightIcons = m.top.findNode("rightIcons")
    m.topTabs = m.categoryTabs ' alias for legacy refs
    m.dropdownOptions = m.categoryTabs ' alias so old refs don't crash

    ' Icon buttons in the right sidebar
    m.voiceBoxButton = m.top.findNode("voiceBoxButton")
    m.sortButton = m.top.findNode("sortButton")
    m.sortOrderButton = m.top.findNode("sortOrderButton")
    m.filterButton = m.top.findNode("filterButton")
    m.viewButton = m.top.findNode("viewButton")
    m.librarySettingsButton = m.top.findNode("librarySettingsButton")

    m.leftArrow = m.top.findNode("leftArrow")
    m.rightArrow = m.top.findNode("rightArrow")
    ' userName removed
    m.tagTitle = m.top.findNode("tagTitle")
    m.loadingSpinner = m.top.findNode("loadingSpinner")

    ' Dummy nodes so legacy voiceBox/voiceBoxBackground references don't crash
    m.voiceBox = createObject("roSGNode", "Rectangle")
    m.voiceBoxBackground = createObject("roSGNode", "Rectangle")

    accentColor = getControlAccentColor(ColorPalette.HIGHLIGHT)
    ' Set accent color on all sidebar icons
    m.allRightIcons = [m.voiceBoxButton, m.sortButton, m.sortOrderButton, m.filterButton, m.viewButton, m.librarySettingsButton]
    for each iconNode in m.allRightIcons
        if isValid(iconNode) then iconNode.focusColor = accentColor
    end for

    m.selectedTag = ""
    ' After TagDetails back: scroll/focus restore (title match beats stale index)
    m.tagsExitRestoreTitle = ""
    m.tagsExitRestoreIndex = -1
    m.cachedTagsData = invalid
    m.cachedTagsContentNode = invalid
end sub

sub init()
    m.favoritesOptionText = tr("Add To Favorites")
    m.showOptionMenu = false

    m.itemGridCounter = 0
    m.disabledReason = string.EMPTY
    m.searchButtonDisabled = false
    m.top.optionsAvailable = false
    setupNodes()
    m.bypassSearchEvent = false

    ' GridItemSmall draws its own focusOutline Ã¢â‚¬â€ disable the MarkupGrid default to avoid double-highlight
    if isValid(m.itemGrid) then m.itemGrid.drawFocusFeedback = false
    if isValid(m.genreList) then m.genreList.drawFocusFeedback = false
    if isValid(m.tagList) then m.tagList.drawFocusFeedback = false

    m.overhang.isVisible = false

    m.swapAnimation.observeField("state", "swapDone")
    m.options.observeField("visible", "onOptionsVisibleChange")

    m.loadedRows = 0
    m.loadedItems = 0

    m.data = CreateObject("roSGNode", "ContentNode")
    m.itemGrid.observeField("itemFocused", "onItemFocused")
    m.itemGrid.observeFieldScoped("itemSelected", "onItemSelected")
    m.itemGrid.content = m.data

    m.genreData = CreateObject("roSGNode", "ContentNode")
    m.genreList.observeFieldScoped("itemFocused", "onGenreItemFocused")
    m.genreList.observeFieldScoped("rowItemFocused", "onGenreRowBackdrop")
    m.genreList.observeFieldScoped("itemSelected", "onGenreItemSelected")
    m.genreList.content = m.genreData

    'Voice filter setup
    m.voiceBox.observeField("text", "onvoiceFilter")

    'backdrop
    m.newBackdrop.observeField("loadStatus", "newBGLoaded")

    'Background Image Queued for loading
    m.queuedBGUri = string.EMPTY
    m.queuedFullBleedBGUri = string.EMPTY

    'Item sort
    m.sortField = "SortName"
    m.sortAscending = true

    m.filter = "All"
    m.filterOptions = {}

    m.view = "presentation"

    m.loadItemsTask1 = createObject("roSGNode", "LoadItemsTask")
    m.isInMyListTask = createObject("roSGNode", "LoadItemsTask")
    m.isInMyListTask.itemsToLoad = "isInMyList"

    m.loadItemsTask = createObject("roSGNode", "LoadItemsTask2")
    m.loadLogoTask = createObject("roSGNode", "LoadItemsTask2")
    m.getFiltersTask = createObject("roSGNode", "GetFiltersTask")

    'set inital counts for overhang before content is loaded.
    m.loadItemsTask.observeField("content", "ItemDataLoaded")
    m.loadItemsTask.totalRecordCount = 0

    ' No legacy voiceBox setup needed in new layout

    m.categoryTabs = m.top.findNode("categoryTabs")
    m.categoryTabs.observeField("itemSelected", "onCategorySelected")
    m.categoryTabs.observeField("itemFocused", "onCategoryFocused")

    m.tabFocusIndex = 0
    m.tabSelectedIndex = 0

    m.reentryGuardActive = false
    m.movieTopTabCategories = ["Movies", "Suggestions", "Trailers", "Playlists", "Collections", "Favorites", "Genres", "Tags", "Folders"]

    m.searchButton = m.top.findNode("searchButton")
    m.settingsButton = m.top.findNode("settingsButton")

    accentColor = ColorPalette.HIGHLIGHT
    m.tabSelectionGuard = false
    m.applyMovieGuard = false

    m.searchButton.background = "#00000000"
    m.searchButton.focusBackground = accentColor
    m.searchButton.iconBlendColor = ColorPalette.WHITE
    m.searchButton.focusIconBlendColor = ColorPalette.DARKGREY
    m.settingsButton.background = "#00000000"
    m.settingsButton.focusBackground = accentColor
    m.settingsButton.iconBlendColor = ColorPalette.WHITE
    m.settingsButton.focusIconBlendColor = ColorPalette.DARKGREY

    m.searchButton.observeField("buttonSelected", "onSearchButtonSelected")
    m.settingsButton.observeField("buttonSelected", "onSettingsButtonSelected")

    if isValid(m.selectedItemOverview)
        m.selectedItemOverview.color = ColorPalette.WHITE
    end if

    if isValid(m.selectedItemOverview)
        m.selectedItemOverview.color = ColorPalette.WHITE
    end if

end sub


sub onSearchButtonSelected()
    m.top.getScene().jumpTo = {
        selectionType: "search"
    }
end sub

sub onSettingsButtonSelected()
    m.top.getScene().jumpTo = {
        selectionType: "settings"
    }
end sub

sub onCategoryFocused()
    index = m.categoryTabs.itemFocused
    itemWidth = 220 + 20 ' itemSize + itemSpacing

    ' Shifting logic per menu.md / Embyold:
    ' 0-5: Movies, Suggestions, Trailers, Playlists, Collections, Favorites - shift 0
    ' 6: Genres - shift 1
    ' 7: Tags - shift 2
    ' 8: Folders - shift 3
    ' Each shift moves 240px left. Clipping rect is 1420px (~6 items visible).
    
    shift = 0
    if index >= 6
        shift = index - 5
    end if

    m.categoryTabs.translation = [-shift * itemWidth, 0]

    if isValid(m.leftArrow) then m.leftArrow.visible = (shift > 0)
    if isValid(m.rightArrow) then m.rightArrow.visible = (index < 8)
end sub

sub onCategorySelected()
    if not isValid(m.categoryTabs.content) then return
    index = m.categoryTabs.itemFocused
    item = m.categoryTabs.content.getChild(index)
    if not isValid(item) then return

    tabName = item.title
    if isMovieLibraryView()
        applyMovieCategory(tabName)
        return
    end if

    if not isValidAndNotEmpty(item.id) then return
    if isStringEqual(item.id, m.view) then return

    fakeChoice = { name: item.id, title: tabName }
    m.global.sceneManager.returnData = fakeChoice
    onViewChange()
end sub


function isMovieLibraryView() as boolean
    return isStringEqual(m.top.mediaType, ItemType.MOVIE)
end function

function getActiveMovieCategory() as string
    if isStringEqual(m.filter, "Folders") then return "Folders"
    if isStringEqual(m.filter, "Trailers") then return "Trailers"
    if isStringEqual(m.filter, "Playlists") then return "Playlists"
    if isStringEqual(m.filter, "Collections") then return "Collections"
    if isStringEqual(m.filter, "Favorites") then return "Favorites"
    if isStringEqual(m.view, "tags") or isStringEqual(m.view, "Tags") or isStringEqual(m.view, "TagDetails") then return "Tags"
    if isStringEqual(m.view, "presentation") then return "Suggestions"
    if isStringEqual(m.view, "genres") or isStringEqual(m.view, "Genres") then return "Genres"
    return "Movies"
end function



function getTabSettingsKey() as string
    key = "display." + m.top.parentItem.Id
    if isMovieLibraryView()
        cat = getActiveMovieCategory()
        if not isStringEqual(cat, "Movies")
            key = key + "." + cat
        end if
    end if
    return key
end function

sub loadTabState()
    key = getTabSettingsKey()
    settings = m.global.session.user.settings
    if not isValid(settings) then return

    if isValidAndNotEmpty(settings[key + ".sortField"]) then m.sortField = settings[key + ".sortField"]
    if isValidAndNotEmpty(settings[key + ".filter"]) then m.filter = settings[key + ".filter"]
    if isValidAndNotEmpty(settings[key + ".landing"]) then m.view = settings[key + ".landing"]

    if isValidAndNotEmpty(settings[key + ".filterOptions"])
        parsed = ParseJson(settings[key + ".filterOptions"])
        if isValid(parsed) then m.filterOptions = parsed
    end if

    if isValid(settings[key + ".sortAscending"])
        m.sortAscending = (settings[key + ".sortAscending"].toStr() = "true")
    end if
end sub

sub applyMovieCategory(tabName as string)
    if m.applyMovieGuard = true then return
    m.applyMovieGuard = true

    if not isString(tabName) or tabName = ""
        m.applyMovieGuard = false
        return
    end if

    newView = m.view
    newFilter = m.filter

    if isStringEqual(tabName, "Movies")
        newView = "grid"
        newFilter = "All"
    else if isStringEqual(tabName, "Suggestions")
        newView = "presentation"
        newFilter = "All"
    else if isStringEqual(tabName, "Favorites")
        newView = "grid"
        newFilter = "Favorites"
    else if isStringEqual(tabName, "Genres")
        newView = "Genres"
        newFilter = "All"
    else if isStringEqual(tabName, "Trailers")
        newView = "grid"
        newFilter = "Trailers"
    else if isStringEqual(tabName, "Playlists")
        newView = "grid"
        newFilter = "Playlists"
    else if isStringEqual(tabName, "Collections")
        newView = "grid"
        newFilter = "Collections"
    else if LCase(tabName) = "tags"
        newView = "Tags"
        newFilter = "All"
    else if isStringEqual(tabName, "Folders")
        newView = "grid"
        newFilter = "Folders"
    else if isStringEqual(tabName, "Search")
        onSearchButtonSelected()
        return
    else if isStringEqual(tabName, "Settings")
        onSettingsButtonSelected()
        return
    else
        return
    end if

    viewChanged = not isStringEqual(newView, m.view)
    filterChanged = not isStringEqual(newFilter, m.filter)

    m.view = newView
    m.filter = newFilter

    ' Load independent settings for this specific tab
    loadTabState()

    ' Update the UI layout to match the new view mode
    setupUILayoutForView()

    if viewChanged or filterChanged
        reloadCategoryResults()
    end if

    m.applyMovieGuard = false
end sub

sub reloadCategoryResults()
    m.loadItemsTask.control = "STOP"
    m.loadItemsTask.view = m.view
    m.loadItemsTask.filter = m.filter

    if isStringEqual(m.view, "Genres")
        m.loadItemsTask.view = "Genres"
        m.loadItemsTask.genreIds = m.top.parentItem.id
        m.loadItemsTask.itemId = m.top.parentItem.parentFolder
        m.loadItemsTask.studioIds = m.top.parentItem.Id
    else if isStringEqual(m.view, "Tags")
        m.loadItemsTask.view = "Tags"
        m.loadItemsTask.genreIds = string.EMPTY
        ' If in tag subfolder, use parentFolder; otherwise use Id for tag list
        if isValid(m.top.parentItem.parentFolder) and LCase(chainLookupReturn(m.top.parentItem, "json.type", chainLookupReturn(m.top.parentItem, "type", string.EMPTY))) = "tag"
            m.loadItemsTask.itemId = m.top.parentItem.parentFolder
        else
            m.loadItemsTask.itemId = m.top.parentItem.Id
        end if
        m.loadItemsTask.studioIds = string.EMPTY
    else
        m.loadItemsTask.itemId = m.top.parentItem.Id
        m.loadItemsTask.genreIds = string.EMPTY
        m.loadItemsTask.studioIds = string.EMPTY
    end if

    m.loadedRows = 0
    m.loadedItems = 0
    m.data = CreateObject("roSGNode", "ContentNode")
    m.itemGrid.content = m.data
    m.genreData = CreateObject("roSGNode", "ContentNode")
    m.genreList.content = m.genreData

    m.loadItemsTask.startIndex = 0
    m.loadItemsTask.control = "RUN"
end sub

' VoiceTextEditBox.voiceEnabled doesn't have alwaysNotify enabled
' To trigger a change event, we must change the value to something else, then back to the value we want
sub onVoiceEnabledChange()
    if m.voiceBox.hasField("voiceEnabled")
        m.voiceBox.voiceEnabled = m.searchButtonDisabled
        m.voiceBox.voiceEnabled = not m.searchButtonDisabled
    end if
end sub

sub onMicIconBlendColorChange()
    if not isValid(m.micIcon) then return
    ' DARKGREY: 269488383
    ' WHITE: -1
    ' LIGHTGREY: -1431655681
    ' HIGHLIGHT: -9934849

    if m.voiceBoxBackground.blendColor = -9934849
        if m.micIcon.blendColor <> -1
            m.micIcon.blendColor = ColorPalette.WHITE
        end if
    else
        if m.micIcon.blendColor <> 269488383
            m.micIcon.blendColor = ColorPalette.DARKGREY
        end if
    end if
end sub

sub OnScreenHidden()
    if not m.overhang.isVisible
        m.overhang.disableMoveAnimation = true
        m.overhang.isVisible = true
        m.overhang.disableMoveAnimation = false
    end if
end sub

sub OnScreenShown()
    ' Block spurious itemSelected events when regaining focus after popping a detail scene.
    ' Reset BOTH the local guard AND the global guard to the same 1.0s window so they stay in sync.
    m.reentryGuardActive = true
    if m.reentryGuardTimer <> invalid
        m.reentryGuardTimer.control = "stop"
        m.reentryGuardTimer = invalid
    end if
    m.reentryGuardTimer = CreateObject("roSGNode", "Timer")
    m.reentryGuardTimer.duration = 1.0
    m.reentryGuardTimer.observeField("fire", "onReentryGuardExpired")
    m.reentryGuardTimer.control = "start"

    ' Also reset the global guard in case BaseScene's timer already expired
    m.global.reentryGuardActive = true
    if isValid(m.global.reentryGuardTimer)
        m.global.reentryGuardTimer.control = "stop"
        m.global.reentryGuardTimer.control = "start"
    end if

    redrawItems()

    m.overhang.isVisible = false
    m.showOptionMenu = false

    group = m.global.sceneManager.callFunc("getActiveScene")

    if isValid(m.top.lastFocus)
        m.top.lastFocus.setFocus(true)
        group.lastFocus = m.top.lastFocus

        focusedItem = getItemFocused()

        if isValid(focusedItem)
            m.loadItemsTask1.itemId = focusedItem.LookupCI("id")
            m.loadItemsTask1.observeField("content", "onItemDataLoaded")
            m.loadItemsTask1.itemsToLoad = "metaData"
            m.loadItemsTask1.control = TaskControl.RUN
        end if

    else
        m.top.setFocus(true)
        group.lastFocus = m.top
    end if
end sub

sub onItemDataLoaded()
    itemData = m.loadItemsTask1.content
    m.loadItemsTask1.unobserveField("content")
    m.loadItemsTask1.control = TaskControl.STOP
    m.loadItemsTask1.content = []

    if not isValidAndNotEmpty(itemData) then return

    focusedItem = getItemFocused()
    if not isValid(focusedItem) then return

    focusedItem.callFunc("setWatched", chainLookupReturn(itemData[0], "json.UserData.Played", false), chainLookupReturn(itemData[0], "json.UserData.UnplayedItemCount", 0))

    m.favoritesOptionText = chainLookupReturn(itemData[0], "json.UserData.IsFavorite", false) ? tr("Remove From Favorites") : tr("Add To Favorites")

    if m.showOptionMenu
        m.isInMyListTask.observeField("content", "onMyListLoaded")
        m.isInMyListTask.control = TaskControl.RUN
    end if
end sub

sub redrawItems()
    ' If user has not set a library level setting, check the user level setting
    if isChainValid(m.global.session, `user.settings.${m.top.parentItem.id}-useLandscapeImages`)
        useLandscapeImages = chainLookupReturn(m.global.session, `user.settings.${m.top.parentItem.id}-useLandscapeImages`, false)
        posterOrientation = useLandscapeImages ? ImageLayout.LANDSCAPE : ImageLayout.DEFAULT
    else
        posterOrientation = chainLookupReturn(m.global, "session.user.settings.libraryPosterOrientation", ImageLayout.DEFAULT)
    end if

    if isStringEqual(posterOrientation, ImageLayout.DEFAULT)
        if inArray([ItemType.PHOTO, ItemType.PHOTOALBUM, ItemType.MUSICVIDEO, ItemType.MYLIST], m.top.mediaType)
            setColumnSizes(ImageLayout.LANDSCAPE)
        else if isStringEqual(m.view, "Episodes")
            setColumnSizes(ImageLayout.LANDSCAPE)
        else
            setColumnSizes(ImageLayout.PORTRAIT)
        end if
    else
        setColumnSizes(posterOrientation)
    end if

    itemGridContent = m.data.getChildren(-1, 0)
    m.data = CreateObject("roSGNode", "ContentNode")
    m.itemGrid.content = m.data
    m.data.appendChildren(itemGridContent)

    ' Reset cursor back to its previous location
    m.itemGrid.jumpToItem = m.itemGrid.itemFocused

    genreContent = m.genreData.getChildren(-1, 0)
    m.genreData = CreateObject("roSGNode", "ContentNode")
    m.genreList.content = m.genreData
    m.genreData.appendChildren(genreContent)

    ' Reset cursor back to its previous location
    m.genreList.jumpToRowItem = m.genreList.rowItemSelected
end sub

'
'Load initial set of Data
sub loadInitialItems()
    m.loadItemsTask.control = TaskControl.STOP
    startLoadingSpinner(false)
    if isValid(m.loadingSpinner)
        m.loadingSpinner.visible = true
        m.loadingSpinner.control = "start"
    end if

    ' No dropdown to toggle in new layout

    ' Read from settings ONLY if the values are not already set in memory
    ' (This prevents state resets during filter/search updates)
    if not isValidAndNotEmpty(m.sortField) then m.sortField = m.global.session.user.settings[getTabSettingsKey() + ".sortField"]
    if not isValidAndNotEmpty(m.filter) then m.filter = m.global.session.user.settings[getTabSettingsKey() + ".filter"]
    if not isValidAndNotEmpty(m.filterOptions) then m.filterOptions = m.global.session.user.settings[getTabSettingsKey() + ".filterOptions"]
    if not isValidAndNotEmpty(m.view) then m.view = m.global.session.user.settings[getTabSettingsKey() + ".landing"]
    if not isValid(m.sortAscending) then m.sortAscending = m.global.session.user.settings[getTabSettingsKey() + ".sortAscending"]

    ' If user has not set a preferred view for this folder, check if they've set a default view
    if not isValid(m.view)
        settingName = `display.${m.top.mediaType}library.defaultview`

        if isStringEqual(m.top.mediaType, ItemType.PHOTOALBUM)
            settingName = `display.${ItemType.PHOTO}library.defaultview`
        end if

        m.view = m.global.session.user.settings[settingName]
    end if

    ' Boxsets are sorted by Premiere Data by default
    if not isValidAndNotEmpty(m.sortField)
        if isStringEqual(getCollectionType(), ItemType.BOXSET)
            m.sortField = "PremiereDate,SortName"
        else if isStringEqual(getCollectionType(), ItemType.MYLIST)
            m.sortField = "OrderAdded"
        else
            m.sortField = "SortName"
        end if
    end if

    if not isValidAndNotEmpty(m.filter) then m.filter = "All"
    if not isValidAndNotEmpty(m.filterOptions) then m.filterOptions = "{}"
    if not isValidAndNotEmpty(m.view) then m.view = "presentation"
    if not isValid(m.sortAscending) then m.sortAscending = true
    if not isStringEqual(type(m.sortAscending), "roBoolean") then m.sortAscending = true

    ' If view is not valid, use default view
    if not inArray(["presentation", "grid", "Genres", "Tags", "Episodes", "TagDetails"], m.view) then m.view = "presentation"

    ' Force presentation mode as default if not set
    if not isStringEqual(m.view, "TagDetails") and not isValid(m.global.session.user.settings[getTabSettingsKey() + ".landing"])
        if isStringEqual(m.top.mediaType, ItemType.MOVIE)
            m.view = "grid" ' Movie libraries default to grid; user selects Suggestions for presentation
        else
            m.view = "presentation"
        end if
    end if

    ' Override to grid mode for genre/tag subfolders only (not top-level movie library)
    if not isStringEqual(m.view, "TagDetails") and isValid(m.top.parentItem.parentFolder)
        if not isStringEqual(m.top.mediaType, ItemType.MOVIE)
            m.view = "grid"
        end if
    end if

    m.filterOptions = ParseJson(m.filterOptions)

    m.loadItemsTask.searchTerm = m.top.searchTerm
    m.loadItemsTask.sortField = m.sortField
    m.loadItemsTask.sortAscending = m.sortAscending
    m.loadItemsTask.filter = m.filter
    m.loadItemsTask.filterOptions = m.filterOptions
    m.loadItemsTask.startIndex = 0
    m.loadItemsTask.studioIds = string.EMPTY
    m.loadItemsTask.tagIds = string.EMPTY
    m.loadItemsTask.tags = string.EMPTY
    m.loadItemsTask.view = string.EMPTY
    m.loadItemsTask.passToItem = {
        libraryID: m.top.parentItem.id
    }

    if isStringEqual(m.view, "Genres")
        m.loadItemsTask.view = "Genres"
        m.loadItemsTask.genreIds = m.top.parentItem.id
        m.loadItemsTask.itemId = m.top.parentItem.parentFolder
        m.loadItemsTask.studioIds = m.top.parentItem.Id
        m.loadItemsTask.tagIds = string.EMPTY
        m.loadItemsTask.tags = string.EMPTY
        if isStringEqual(m.top.mediaType, ItemType.MUSICVIDEO)
            m.loadItemsTask.recursive = true
        end if
    else if isStringEqual(m.view, "Tags")
        m.loadItemsTask.view = "Tags"
        m.loadItemsTask.genreIds = string.EMPTY
        m.loadItemsTask.itemId = m.top.parentItem.Id
        m.loadItemsTask.studioIds = string.EMPTY
        m.loadItemsTask.tagIds = string.EMPTY
        m.loadItemsTask.tags = string.EMPTY
    else if isStringEqual(m.view, "TagDetails")
        m.loadItemsTask.view = "TagDetails"
        m.loadItemsTask.itemId = m.top.parentItem.Id
        m.loadItemsTask.recursive = true
        m.loadItemsTask.tags = m.selectedTag
        m.loadItemsTask.genreIds = string.EMPTY
        m.loadItemsTask.studioIds = string.EMPTY
        m.loadItemsTask.tagIds = string.EMPTY
    else if isStringEqual(m.view, "presentation")
        m.loadItemsTask.itemId = m.top.parentItem.Id
        m.loadItemsTask.studioIds = string.EMPTY
        m.loadItemsTask.genreIds = string.EMPTY
        m.loadItemsTask.tagIds = string.EMPTY
        m.loadItemsTask.tags = string.EMPTY
    else if isStringEqual(m.view, "grid")
        m.loadItemsTask.itemId = m.top.parentItem.Id
        m.loadItemsTask.studioIds = string.EMPTY
        m.loadItemsTask.genreIds = string.EMPTY
        m.loadItemsTask.tagIds = string.EMPTY
        m.loadItemsTask.tags = string.EMPTY
    else if isStringEqual(m.view, "Episodes")
        m.loadItemsTask.itemId = m.top.parentItem.Id
        m.loadItemsTask.studioIds = string.EMPTY
        m.loadItemsTask.genreIds = string.EMPTY
        m.loadItemsTask.tagIds = string.EMPTY
        m.loadItemsTask.tags = string.EMPTY
        if isStringEqual(m.loadItemsTask.sortField, "SortName")
            m.loadItemsTask.sortField = `SeriesSortName,SortName`
        end if
    end if

    m.data = CreateObject("roSGNode", "ContentNode")
    m.itemGrid.content = m.data
    m.loadItemsTask.control = "STOP"

    ' Ensure top bar tabs are built immediately for Movie libraries
    if isStringEqual(m.top.mediaType, ItemType.MOVIE)
        buildTopTabs([])
    end if

    if isStringEqual(m.top.mediaType, ItemType.COLLECTIONFOLDER)
        ' Sort folders to the top of results
        m.loadItemsTask.sortField = `${m.sortField}`
        m.loadItemsTask.itemType = `${ItemType.MUSICVIDEO},${ItemType.FOLDER}`
        m.loadItemsTask.passToItem.addreplace("collectionType", ItemType.MUSICVIDEO)
    end if

    if inArray([ItemType.BOXSET, ItemType.PHOTO, ItemType.PHOTOALBUM, ItemType.MUSICVIDEO], m.top.mediaType)
        m.loadItemsTask.recursive = false

        if isStringEqual(m.top.mediaType, ItemType.MUSICVIDEO)
            ' Sort folders to the top of results
            m.loadItemsTask.sortField = `${m.sortField}`
            m.loadItemsTask.itemType = `${ItemType.MUSICVIDEO},${ItemType.FOLDER}`
            m.loadItemsTask.passToItem.addreplace("collectionType", ItemType.MUSICVIDEO)
        end if

        if isStringEqual(m.top.mediaType, ItemType.BOXSET)
            if not isStringEqual(m.top.parentItem.LookupCI("type"), ItemType.BOXSET)
                if m.loadItemsTask.searchTerm <> string.EMPTY
                    m.loadItemsTask.itemType = ItemType.BOXSET
                    m.loadItemsTask.recursive = true
                end if
            else
                if isValid(m.top.parentItem.parentFolder)
                    disableSearch(tr("Search is unavailable because the API does not support searching inside boxsets."))
                end if
            end if
        end if
    else if isStringEqual(m.view, "Episodes")
        m.loadItemsTask.recursive = true
        m.loadItemsTask.itemType = ItemType.EPISODE
    else
        m.loadItemsTask.itemType = m.top.mediaType
    end if

    ' We're in a genre sub folder
    if isValid(m.top.parentItem.parentFolder) and not isStringEqual(getCollectionType(), CollectionType.BOXSET)
        if not inArray([ItemType.PHOTOALBUM, ItemType.MUSICVIDEO], m.top.mediaType)
            parentItemType = LCase(chainLookupReturn(m.top.parentItem, "json.type", chainLookupReturn(m.top.parentItem, "type", string.EMPTY)))

            m.loadItemsTask.passToItem = {
                libraryID: chainLookupReturn(m.top.parentItem, "libraryID", m.top.parentItem.parentFolder)
            }

            m.loadItemsTask.itemId = m.top.parentItem.parentFolder

            if isStringEqual(parentItemType, "tag")
                print "[TAG_FILTER] Setting up tag filter: tagName=" + chainLookupReturn(m.top.parentItem, "tagName", string.EMPTY) + " parentFolder=" + m.top.parentItem.parentFolder
                m.loadItemsTask.genreIds = string.EMPTY
                m.loadItemsTask.tagIds = chainLookupReturn(m.top.parentItem, "tagId", string.EMPTY)
                m.loadItemsTask.tags = chainLookupReturn(m.top.parentItem, "tagName", string.EMPTY)
            else
                m.loadItemsTask.genreIds = m.top.parentItem.id
                m.loadItemsTask.tagIds = string.EMPTY
                m.loadItemsTask.tags = string.EMPTY
            end if
        end if
    end if

    ' We're inside a music video genre sub folder
    if isStringEqual(m.top.mediaType, ItemType.MUSICVIDEO)
        if isStringEqual(chainLookup(m.top.parentItem, "itemType"), `${ItemType.MUSICVIDEO},${ItemType.FOLDER}`)
            m.loadItemsTask.itemId = m.top.parentItem.id
            m.loadItemsTask.genreIds = m.top.parentItem.id
            m.loadItemsTask.itemType = ItemType.MUSICVIDEO
            m.loadItemsTask.recursive = true
        end if
    end if

    setupUILayoutForView()
end sub

sub setupUILayoutForView()
    ' Fixed grid position — no top bar
    if isStringEqual(m.view, "presentation")
        ' Row rides the bottom edge — y=430 leaves room for poster + 2-line title before y=720
        m.itemGrid.translation = [100, 430 + 23]
        m.itemGrid.numRows = 1
        m.itemGrid.vertFocusAnimationStyle = "fixed"
    else
        m.itemGrid.translation = [100, 165 + 23]
        m.itemGrid.numRows = 2
        m.itemGrid.vertFocusAnimationStyle = "floatingFocus"
    end if



    m.emptyText.translation = [0, 320]
    if isStringEqual(m.view, "presentation")
        m.itemGrid.itemSpacing = [20, 20]
    else
        ' More spacing for grid mode so titles don't overlap the row below
        m.itemGrid.itemSpacing = [20, 45]
    end if

    m.selectedItemOverview.visible = true
    m.infoGroup.visible = true
    m.selectedItemName.visible = true

    ' Always show item titles below tiles
    m.top.showItemTitles = "showalways"

    m.itemLogo.visible = false
    m.backdrop.opacity = 1
    m.newBackdrop.opacity = 0

    m.emptyText.visible = false

    view = LCase(m.view)
    if view = "grid" or view = "tags"
        m.itemGrid.visible = true
        m.itemGrid.opacity = 1.0
        ' floatingFocus animates focusPercent while scrolling; GridItemSmall ring goes transparent
        m.itemGrid.vertFocusAnimationStyle = "fixed"
        m.top.showItemTitles = "showalways"
        m.libraryBackdropFull.opacity = 0
        m.libraryBackdropFull.visible = false
        m.libraryBackdropFullTransition.opacity = 0
        m.libraryBackdropFullTransition.visible = false
        m.itemLogo.visible = false
        m.itemGrid.translation = [100, 0]
        m.emptyText.translation = [0, 540]
        m.itemGrid.numRows = 5
        m.selectedItemOverview.visible = false
        m.selectedItemName.visible = false
        m.infoGroup.visible = false

    else if isStringEqual(m.view, "Episodes")
        m.top.showItemTitles = "showalways"
        m.itemLogo.visible = false
        m.itemGrid.translation = [100, 0]
        m.emptyText.translation = [0, 540]
        m.itemGrid.numRows = 2
        m.selectedItemOverview.visible = false
        m.selectedItemName.visible = false
        m.infoGroup.visible = false

    else if isStringEqual(m.view, "Genres")
        m.top.showItemTitles = "showalways"
        m.itemLogo.visible = false
        m.itemGrid.translation = [100, 0]
        m.emptyText.translation = [0, 540]
        m.itemGrid.numRows = 2
        m.selectedItemOverview.visible = false
        m.selectedItemName.visible = false
        m.infoGroup.visible = false
    end if

    backdropUrl = chainLookupReturn(m.top, "parentItem.backdropUrl", "")
    if isValidAndNotEmpty(backdropUrl)
        SetBackground(backdropUrl)
    else
        SetBackground(string.EMPTY)
    end if

    if isStringEqual(m.top.mediaType, ItemType.MYLIST)
        disableSearch(tr("Search is unavailable because the API does not support searching inside My List."))

        m.itemGrid.itemComponentName = "GridItemMedium"
        m.itemGrid.itemSize = "[400, 330]"
        m.itemGrid.rowHeights = "[330]"
        m.itemGrid.itemSpacing = "[40, 20]"
        m.itemGrid.numColumns = 4
        m.top.imageDisplayMode = "scaleToZoom"
    end if

    if isStringEqual(m.top.mediaType, ItemType.MUSICVIDEO)
        m.itemGrid.itemComponentName = "GridItemMedium"
        m.itemGrid.itemSize = "[400, 330]"
        m.itemGrid.rowHeights = "[330]"
        m.itemGrid.itemSpacing = "[40, 20]"
        m.itemGrid.numColumns = 4
        m.top.imageDisplayMode = "scaleToZoom"

        m.genreList.itemComponentName = "GridItemMedium"
        m.genreList.rowItemSize = "[[400, 330]]"
        m.genreList.rowHeights = "[360]"
    end if

    if inArray([ItemType.PHOTO, ItemType.PHOTOALBUM], m.top.mediaType)
        m.itemGrid.itemComponentName = "GridItemMedium"
        m.itemGrid.itemSize = "[400, 330]"
        m.itemGrid.rowHeights = "[330]"
        m.itemGrid.itemSpacing = "[40, 20]"
        m.itemGrid.numColumns = 4
        m.top.imageDisplayMode = "scaleToZoom"

        m.genreList.itemComponentName = "GridItemMedium"
        m.genreList.rowItemSize = "[[400, 330]]"
        m.genreList.rowHeights = "[360]"
    end if

    alphaDisplayed = m.alpha.callFunc("getDisplay")
    ' Only show alpha picker if sorted by Name/Title and in grid view
    shouldShowAlpha = isStringEqual(m.sortField, "SortName") and isStringEqual(m.view, "grid")

    if isStringEqual(m.view, "Episodes")
        m.itemGrid.itemComponentName = "GridItemMedium"
        m.itemGrid.itemSize = "[400, 330]"
        m.itemGrid.rowHeights = "[330]"
        m.itemGrid.itemSpacing = "[40, 20]"
        m.itemGrid.numColumns = 4
        m.top.imageDisplayMode = "scaleToZoom"
    end if

    if shouldShowAlpha
        if not alphaDisplayed then m.alpha.callFunc("setDisplay", true)
    else
        if alphaDisplayed then m.alpha.callFunc("setDisplay", false)
    end if

    ' If user has not set a library level setting, check the user level setting
    if isChainValid(m.global.session, `user.settings.${m.top.parentItem.id}-useLandscapeImages`)
        useLandscapeImages = chainLookupReturn(m.global.session, `user.settings.${m.top.parentItem.id}-useLandscapeImages`, false)
        posterOrientation = useLandscapeImages ? ImageLayout.LANDSCAPE : ImageLayout.DEFAULT
    else
        posterOrientation = chainLookupReturn(m.global, "session.user.settings.libraryPosterOrientation", ImageLayout.DEFAULT)
    end if

    if isStringEqual(posterOrientation, ImageLayout.DEFAULT)
        if inArray([ItemType.PHOTO, ItemType.PHOTOALBUM, ItemType.MUSICVIDEO, ItemType.MYLIST], m.top.mediaType)
            setColumnSizes(ImageLayout.LANDSCAPE)
        else if isStringEqual(m.view, "Episodes")
            setColumnSizes(ImageLayout.LANDSCAPE)
        else
            setColumnSizes(ImageLayout.PORTRAIT)
        end if
    else
        setColumnSizes(posterOrientation)
    end if

    updateGridFocusFeedbackMode()

    m.loadItemsTask.control = TaskControl.RUN

    filtersParentId = m.top.parentItem.Id
    filterParentType = LCase(chainLookupReturn(m.top.parentItem, "json.type", chainLookupReturn(m.top.parentItem, "type", string.EMPTY)))
    if isStringEqual(filterParentType, "tag") and isValidAndNotEmpty(m.top.parentItem.parentFolder)
        filtersParentId = m.top.parentItem.parentFolder
    end if

    m.getFiltersTask.observeField("filters", "FilterDataLoaded")
    m.getFiltersTask.params = {
        userid: m.global.session.user.id,
        parentid: filtersParentId,
        includeitemtypes: m.loadItemsTask.itemType
    }
    m.getFiltersTask.control = "RUN"
end sub

sub updateGridFocusFeedbackMode()
    ' All item components (GridItemSmall, GridItemMedium, GridItem) draw their own
    ' custom focus ring. Always disable the MarkupGrid built-in highlight to prevent
    ' double-ring rendering.
    if isValid(m.itemGrid)
        m.itemGrid.drawFocusFeedback = false
    end if

    if isValid(m.genreList)
        m.genreList.drawFocusFeedback = false
    end if
end sub

sub setColumnSizes(layout = ImageLayout.PORTRAIT as string)
    if isStringEqual(layout, ImageLayout.PORTRAIT)
        numberOfColumns = val(chainLookupReturn(m.global.session, "user.settings.numberOfColumnsPortrait", "6"))
        imageWidthData = val(chainLookupReturn(m.global.session, "user.settings.numberOfColumnsPortraitData", "230"))
    else
        numberOfColumns = val(chainLookupReturn(m.global.session, "user.settings.numberOfColumnsLandscape", "4"))
        imageWidthData = val(chainLookupReturn(m.global.session, "user.settings.numberOfColumnsLandscapeData", "418"))
    end if

    if isStringEqual(m.top.showItemTitles, "hidealways")
        aspectRatio = isStringEqual(layout, ImageLayout.PORTRAIT) ? ASPECT_RATIO_PORTRAIT_NO_TITLE : ASPECT_RATIO_LANDSCAPE_NO_TITLE
    else
        aspectRatio = isStringEqual(layout, ImageLayout.PORTRAIT) ? ASPECT_RATIO_PORTRAIT_WITH_TITLE : ASPECT_RATIO_LANDSCAPE_WITH_TITLE
    end if

    if isStringEqual(m.view, "presentation")
        ' Story mode needs extra vertical padding so the text doesn't clip
        aspectRatio = isStringEqual(layout, ImageLayout.PORTRAIT) ? 2.4 : 1.15
    end if

    defaultSize = [imageWidthData, CInt(imageWidthData * aspectRatio)]

    m.itemGrid.itemSize = [defaultSize[0] + 12, defaultSize[1] + 12]
    m.itemGrid.rowHeights = [defaultSize[1] + 12]

    if isStringEqual(m.view, "presentation")
        ' Available vertical space = 920 - gridY.
        gridY = m.itemGrid.translation[1]

        ' Restore normal tile sizes by removing the height cap.
        m.itemGrid.numRows = 1
    else
        ' Force exactly 2 visible rows in grid mode so the user sees 2 rows and scrolls vertically.
        ' Cap item height so 2 rows + spacing always fit within contentGroup clippingRect (920px).
        maxItemHeight = int((920 - m.itemGrid.itemSpacing[1]) / 2)
        if defaultSize[1] > maxItemHeight
            defaultSize[1] = maxItemHeight
            m.itemGrid.itemSize = [defaultSize[0] + 12, defaultSize[1] + 12]
            m.itemGrid.rowHeights = [defaultSize[1] + 12]
        end if
        m.itemGrid.numRows = 2
    end if

    m.loadItemsTask.numberOfColumns = numberOfColumns
    m.itemGrid.numColumns = numberOfColumns

    if isStringEqual(m.view, "grid") or isStringEqual(m.view, "Tags")
        ' itemSpacing reduced by 12 to account for the internal padding in components
        m.itemGrid.itemSpacing = [8, 33]
        m.rightIcons.visible = true
    else
        m.rightIcons.visible = false
    end if

    m.genreList.itemSize = [1900, defaultSize[1] + 42]
    m.genreList.rowItemSize = [[defaultSize[0] + 12, defaultSize[1] + 12]]
    m.genreList.rowItemSpacing = [[8, 0]]
    m.genreList.rowHeights = [defaultSize[1] + 42]
    m.genreList.numRows = abs(1180 / (defaultSize[1] + m.genreList.itemSpacing[1]))

    m.genreList.numRows = abs(1180 / (defaultSize[1] + m.genreList.itemSpacing[1]))
end sub

function setOptions() as object
    if isStringEqual(m.top.mediaType, ItemType.MOVIE)
        return setMovieOptions()
    end if

    if isStringEqual(m.top.mediaType, ItemType.BOXSET)
        return setMovieOptions()
    end if

    if isStringEqual(m.top.mediaType, ItemType.MYLIST)
        return setMovieOptions()
    end if

    if isStringEqual(m.top.mediaType, ItemType.SERIES)
        return setSeriesOptions()
    end if

    if isStringEqual(m.top.mediaType, ItemType.MUSICVIDEO)
        return setMusicVideoOptions()
    end if

    if inArray([ItemType.PHOTO, ItemType.PHOTOALBUM], m.top.mediaType)
        return setPhotoOptions()
    end if

    return {
        filter: []
    }
end function

' Set view, sort, and filter options
function setMovieOptions() as object
    options = {
        filter: []
    }

    options.views = [
        { "Title": tr("Story"), "Name": "presentation", "Track": { "description": tr("Story") } },
        { "Title": tr("Grid"), "Name": "grid", "Track": { "description": tr("Grid") } }
    ]

    if not isStringEqual(m.top.mediaType, ItemType.MYLIST)
        options.views.push({ "Title": tr("Genres"), "Name": "Genres", "Track": { "description": tr("Genres") } })
    end if

    options.sort = [
        { "Title": tr("TITLE"), "Name": "SortName", "Track": { "description": tr("TITLE") } },
        { "Title": tr("Community Rating"), "Name": "CommunityRating,SortName", "Track": { "description": tr("Community Rating") } },
        { "Title": tr("Critics Rating"), "Name": "CriticRating,SortName", "Track": { "description": tr("Critics Rating") } },
        { "Title": tr("DATE_ADDED"), "Name": "DateCreated,SortName", "Track": { "description": tr("DATE_ADDED") } },
        { "Title": tr("DATE_PLAYED"), "Name": "DatePlayed,SortName", "Track": { "description": tr("DATE_PLAYED") } },
        { "Title": tr("Parental Rating"), "Name": "OfficialRating,SortName", "Track": { "description": tr("Parental Rating") } },
        { "Title": tr("PLAY_COUNT"), "Name": "PlayCount,SortName", "Track": { "description": tr("PLAY_COUNT") } },
        { "Title": tr("RELEASE_DATE"), "Name": "PremiereDate,SortName", "Track": { "description": tr("RELEASE_DATE") } },
        { "Title": tr("RUNTIME"), "Name": "Runtime,SortName", "Track": { "description": tr("RUNTIME") } },
        { "Title": tr("Random"), "Name": "Random", "Track": { "description": tr("Random") } }
    ]

    options.filter = [
        { "Title": tr("All"), "Name": "All" },
        { "Title": tr("Played"), "Name": "Played" },
        { "Title": tr("Unplayed"), "Name": "Unplayed" },
        { "Title": tr("Resumable"), "Name": "Resumable" },
        { "Title": tr("Favorites"), "Name": "Favorites" }
    ]

    if inArray([ItemType.BOXSET, CollectionType.BOXSETS], getCollectionType())
        options.views = [
            { "Title": tr("Story"), "Name": "presentation", "Track": { "description": tr("Story") } },
            { "Title": tr("Grid"), "Name": "grid", "Track": { "description": tr("Grid") } }
        ]
    end if

    if inArray([ItemType.MYLIST], getCollectionType())
        options.sort.unshift({ "Title": tr("Order Added"), "Name": "OrderAdded", "Track": { "description": tr("Order Added") } })
    end if

    if isStringEqual(m.view, "genres")
        options.sort = [{ "Title": tr("TITLE"), "Name": "SortName", "Track": { "description": tr("TITLE") } }]
        options.filter = [{ "Title": tr("All"), "Name": "All" }]
    end if

    ' If we're in a genre subfolder
    if isValid(m.top.parentItem.parentFolder)
        options.views = [
            { "Title": tr("Story"), "Name": "presentation", "Track": { "description": tr("Story") } },
            { "Title": tr("Grid"), "Name": "grid", "Track": { "description": tr("Grid") } }
        ]
    end if

    return options
end function

