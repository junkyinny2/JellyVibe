function setSeriesOptions() as object
    options = {
        filter: []
    }

    options.views = [
        { "Title": tr("Story"), "Name": "presentation", "Track": { "description": tr("Story") } },
        { "Title": tr("Grid"), "Name": "grid", "Track": { "description": tr("Grid") } },
        { "Title": tr("Genres"), "Name": "Genres", "Track": { "description": tr("Genres") } },
        { "Title": tr("Episodes"), "Name": "Episodes", "Track": { "description": tr("Episodes") } }
    ]

    options.sort = [
        { "Title": tr("TITLE"), "Name": "SortName", "Track": { "description": tr("TITLE") } },
        { "Title": tr("Community Rating"), "Name": "CommunityRating,SortName", "Track": { "description": tr("Community Rating") } },
        { "Title": tr("Date Show Added"), "Name": "DateCreated,SortName", "Track": { "description": tr("Date Show Added") } },
        { "Title": tr("Date Episode Added"), "Name": "DateLastContentAdded,SortName", "Track": { "description": tr("Date Episode Added") } },
        { "Title": tr("DATE_PLAYED"), "Name": "SeriesDatePlayed,SortName", "Track": { "description": tr("DATE_PLAYED") } },
        { "Title": tr("OFFICIAL_RATING"), "Name": "OfficialRating,SortName", "Track": { "description": tr("OFFICIAL_RATING") } },
        { "Title": tr("RELEASE_DATE"), "Name": "PremiereDate,SortName", "Track": { "description": tr("RELEASE_DATE") } },
        { "Title": tr("Random"), "Name": "Random", "Track": { "description": tr("Random") } }
    ]

    options.filter = [
        { "Title": tr("All"), "Name": "All" },
        { "Title": tr("Played"), "Name": "Played" },
        { "Title": tr("Unplayed"), "Name": "Unplayed" },
        { "Title": tr("Favorites"), "Name": "Favorites" }
    ]

    if isStringEqual(m.view, "genres")
        options.sort = [{ "Title": tr("TITLE"), "Name": "SortName", "Track": { "description": tr("TITLE") } }]
        options.filter = [{ "Title": tr("All"), "Name": "All" }]
    end if

    ' If we're in a genre subfolder
    if isValid(m.top.parentItem.parentFolder)
        options.views = [
            { "Title": tr("Story"), "Name": "presentation", "Track": { "description": tr("Story") } },
            { "Title": tr("Grid"), "Name": "grid", "Track": { "description": tr("Grid") } }
        ]
    end if

    return options
end function

' Return parent collection type
function getCollectionType() as string
    if m.top.parentItem.collectionType <> invalid then return m.top.parentItem.collectionType
    return m.top.parentItem.Type
end function

' Search string array for search value. Return if it's found
function inStringArray(array, searchValue) as boolean
    for each item in array
        if lcase(item) = lcase(searchValue) then return true
    end for
    return false
end function

' Build the top tab buttons from view options
sub buildTopTabs(views as object)
    if not isValid(m.categoryTabs) then return

    content = createObject("roSGNode", "ContentNode")
    selectedIndex = 0

    if isMovieLibraryView()
        selectedCategory = getActiveMovieCategory()
        for i = 0 to m.movieTopTabCategories.count() - 1
            cat = m.movieTopTabCategories[i]
            item = content.createChild("ContentNode")
            item.title = cat
            item.id = cat
            item.selected = isStringEqual(cat, selectedCategory)
            if item.selected then selectedIndex = i
        end for
    else
        for i = 0 to views.count() - 1
            viewOption = views[i]
            item = content.createChild("ContentNode")
            item.title = tr(viewOption.LookupCI("title"))
            item.id = viewOption.LookupCI("name")
            item.selected = isStringEqual(item.id, m.view)
            if item.selected then selectedIndex = i
        end for
    end if

    m.categoryTabs.content = content
    m.categoryTabs.numColumns = content.getChildCount()
    if content.getChildCount() > 0
        m.categoryTabs.jumpToItem = selectedIndex
    end if
end sub

sub focusCategoryTabsAtEnd()
    if not isValid(m.categoryTabs) then return
    m.categoryTabs.setFocus(true)

    if isValid(m.categoryTabs.content)
        endIndex = m.categoryTabs.content.getChildCount() - 1
        if endIndex >= 0
            m.categoryTabs.jumpToItem = endIndex
        end if
    end if
end sub

function isFocusedCategoryTabLast() as boolean
    if not isValid(m.categoryTabs) or not isValid(m.categoryTabs.content) then return false
    focusedIndex = m.categoryTabs.itemFocused
    if not isValid(focusedIndex) then focusedIndex = 0
    return focusedIndex >= m.categoryTabs.content.getChildCount() - 1
end function

function focusGridFromTopMenu() as boolean
    if m.loadedItems = 0 then return true
    m.itemGrid.setFocus(m.itemGrid.opacity = 1)
    m.genreList.setFocus(m.genreList.opacity = 1)
    group = m.global.sceneManager.callFunc("getActiveScene")
    group.lastFocus = m.itemGrid.opacity = 1 ? m.itemGrid : m.genreList
    m.itemGrid.scrollDirection = "vertical"
    return true
end function

function handleCategoryTabDirectionalNav(key as string) as boolean
    if not m.categoryTabs.isInFocusChain() then return false

    if isStringEqual(key, KeyCode.RIGHT)
        if isFocusedCategoryTabLast()
            m.searchButton.setFocus(true)
            return true
        end if
    end if

    return false
end function


' handleFoldersTabNavigation removed as it is now part of categoryTabs

function handleTopUtilityNavigation(key as string) as boolean
    if m.searchButton.isinFocusChain()
        if isStringEqual(key, KeyCode.LEFT)
            focusCategoryTabsAtEnd()
            return true
        else if isStringEqual(key, KeyCode.RIGHT)
            m.settingsButton.setFocus(true)
            return true
        else if isStringEqual(key, KeyCode.DOWN)
            return focusGridFromTopMenu()
        else if isStringEqual(key, KeyCode.OK)
            onSearchButtonSelected()
            return true
        end if
    else if m.settingsButton.isinFocusChain()
        if isStringEqual(key, KeyCode.LEFT)
            m.searchButton.setFocus(true)
            return true
        else if isStringEqual(key, KeyCode.DOWN)
            return focusGridFromTopMenu()
        else if isStringEqual(key, KeyCode.OK)
            onSettingsButtonSelected()
            return true
        end if
    end if

    return false
end function

' Data to display when options button selected
sub setSelectedOptions(options)

    ' Set selected view option - now handled by buildTopTabs
    for each o in options.views
        if o.Name = m.view
            o.Selected = true
        end if
    end for

    ' Set selected sort option
    for each o in options.sort
        if o.Name = m.sortField
            o.Selected = true
        end if
    end for

    ' Set selected filter
    for each o in options.filter
        if o.Name = m.filter
            o.Selected = true
            m.options.filter = o.Name
        end if

        ' Select selected filter options
        if isValid(o.options) and isValid(m.filterOptions)
            if o.options.Count() > 0 and m.filterOptions.Count() > 0
                if LCase(o.Name) = LCase(m.filterOptions.keys()[0])
                    selectedFilterOptions = m.filterOptions[m.filterOptions.keys()[0]].split(o.delimiter)
                    checkedState = []

                    for each availableFilterOption in o.options
                        matchFound = false

                        for each selectedFilterOption in selectedFilterOptions
                            if LCase(toString(availableFilterOption).trim()) = LCase(selectedFilterOption.trim())
                                matchFound = true
                            end if
                        end for

                        checkedState.push(matchFound)
                    end for

                    o.checkedState = checkedState
                end if
            end if
        end if
    end for

    m.options.options = options
    if isValid(m.sortOrderButton)
        m.sortOrderButton.iconUri = m.sortAscending ? "pkg:/images/icons/up_white.png" : "pkg:/images/icons/down_white.png"
    end if
end sub

'
' Logo Image Loaded Event Handler
sub FilterDataLoaded(msg)
    options = setOptions()

    data = msg.GetData()
    m.getFiltersTask.unobserveField("filters")

    if not isValid(data) then return

    ' Add filters from the API data
    if inArray(["presentation", "grid"], m.view)
        options.filter.push({ "Title": tr("Features"), "Name": "Features", "Options": ["Subtitles", "Special Features", "Theme Song", "Theme Video"], "Delimiter": "|", "CheckedState": [] })

        if isValidAndNotEmpty(data.genres)
            options.filter.push({ "Title": tr("Genres"), "Name": "Genres", "Options": data.genres, "Delimiter": "|", "CheckedState": [] })
        end if

        if isValidAndNotEmpty(data.OfficialRatings)
            options.filter.push({ "Title": tr("Parental Ratings"), "Name": "OfficialRatings", "Options": data.OfficialRatings, "Delimiter": "|", "CheckedState": [] })
        end if

        if isValidAndNotEmpty(data.Years)
            options.filter.push({ "Title": tr("Years"), "Name": "Years", "Options": data.Years, "Delimiter": ",", "CheckedState": [] })
        end if
    end if

    setSelectedOptions(options)
    m.options.options = options
    buildTopTabs(options.views)
end sub


'
' Logo Image Loaded Event Handler
sub LogoImageLoaded(msg)
    data = msg.GetData()
    m.loadLogoTask.unobserveField("content")
    m.loadLogoTask.content = []

    if not isStringEqual(m.view, "presentation")
        m.itemLogo.visible = false
        return
    end if

    if data.Count() > 0
        m.itemLogo.uri = data[0]
        m.itemLogo.visible = true
    else
        m.selectedItemName.visible = true
    end if
end sub

'
'Handle loaded data, and add to Grid
sub ItemDataLoaded(msg)
    itemData = msg.GetData()

    if itemData = invalid
        return
    end if

    group = m.global.sceneManager.callFunc("getActiveScene")

    if LCase(m.view) = "tags"
        m.data.removeChildren(m.data.getChildren(-1, 0))
        if itemData <> invalid and itemData.Count() > 0
            m.data.appendChildren(itemData)
            m.cachedTagsContentNode = m.data ' Cache the whole ContentNode for instant restore
            m.emptyText.visible = false
        else
            m.emptyText.text = tr("No tags found on this server.")
            m.emptyText.visible = true
        end if
        m.loadedItems = m.data.getChildCount()
        m.itemGrid.opacity = 1.0
        m.itemGrid.visible = true
        m.itemGrid.vertFocusAnimationStyle = "fixed"
        m.itemGrid.setFocus(true)
        scheduleTagsGridRestoreFocus()

        if isValid(m.loadingSpinner)
            m.loadingSpinner.visible = false
            m.loadingSpinner.control = "stop"
        end if
        stopLoadingSpinner()
        return
    end if

    if isStringEqual(m.view, "Genres")
        ' Reset genre list data
        m.genreData.removeChildren(m.genreData.getChildren(-1, 0))

        for each item in itemData
            m.genreData.appendChild(item)
        end for

        m.loadedItems = m.genreData.getChildCount()

        m.itemGrid.opacity = 0
        m.genreList.opacity = 1

        if not m.categoryTabs.isinFocusChain()
            m.genreList.setFocus(true)
            group = m.global.sceneManager.callFunc("getActiveScene")
            group.lastFocus = m.genreList
        end if

        if isValid(m.loadingSpinner)
            m.loadingSpinner.visible = false
            m.loadingSpinner.control = "stop"
        end if
        stopLoadingSpinner()

        ' Return focus to options menu if it was opened while library was loading
        if m.options.visible
            m.options.setFocus(true)
            group.lastFocus = m.options
        end if

        if m.loadedItems = 0
            m.emptyText.text = tr("No items found. Try adjusting your selected filters.")
            m.emptyText.visible = true
            m.voiceBox.setfocus(true)
            setSearchBackground(SearchButtonState.ACTIVE)
            group = m.global.sceneManager.callFunc("getActiveScene")
            group.lastFocus = m.voiceBox
        end if

        return
    end if

    ' keep focus on alpha menu if it's active
    if m.top.alphaActive
        m.alphaMenu.setFocus(true)
        group = m.global.sceneManager.callFunc("getActiveScene")
        group.lastFocus = m.alphaMenu
    else
        m.itemGrid.opacity = "1"
        m.genreList.opacity = "0"

        if not m.categoryTabs.isinFocusChain()
            m.alphaMenu.setFocus(false)
            m.itemGrid.setFocus(true)
            m.genreList.setFocus(false)
            group = m.global.sceneManager.callFunc("getActiveScene")
            group.lastFocus = m.itemGrid
        end if

    end if

    if m.data.getChildCount() = 0
        m.itemGrid.jumpToItem = 0
    end if

    m.data.appendChildren(itemData)

    'Update the stored counts
    m.loadedItems = m.data.getChildCount()
    if isValid(m.itemGrid)
        if m.itemGrid.numColumns <> invalid and m.itemGrid.numColumns > 0
            m.loadedRows = m.loadedItems / m.itemGrid.numColumns
        else
            m.loadedRows = 0
        end if
    else
        m.loadedRows = 0
    end if

    onItemFocused()

    ' For presentation mode: force preview of first item on initial load
    if isStringEqual(m.view, "presentation") and m.loadedItems > 0
        if m.itemGrid.itemFocused < 0 then m.itemGrid.jumpToItem = 0
        onItemFocused()
    end if

    'If there are no items to display, show message
    if m.loadedItems = 0
        m.selectedItemOverview.visible = false
        m.infoGroup.visible = false

        m.itemLogo.visible = false
        m.itemLogo.uri = string.EMPTY

        m.selectedItemName.visible = false

        SetName(string.EMPTY)
        SetOverview(string.EMPTY)
        SetOfficialRating(string.EMPTY)
        SetProductionYear(string.EMPTY)
        setFieldText("runtime", string.EMPTY)
        setFieldText("communityRating", string.EMPTY)
        setFieldText("criticRatingLabel", string.EMPTY)
        m.criticRatingIcon.uri = string.EMPTY
        m.star.uri = string.EMPTY

        m.newBackdrop.opacity = 0
        m.backdrop.opacity = 0

        m.emptyText.text = tr("No items found. Try adjusting your selected filters.")
        m.emptyText.visible = true
        m.voiceBox.setfocus(true)
        setSearchBackground(SearchButtonState.ACTIVE)
        group = m.global.sceneManager.callFunc("getActiveScene")
        group.lastFocus = m.voiceBox
    end if

    stopLoadingSpinner()
    ' Return focus to options menu if it was opened while library was loading
    if m.options.visible
        m.options.setFocus(true)
        group = m.global.sceneManager.callFunc("getActiveScene")
        group.lastFocus = m.options
    end if
end sub

'
'Set Selected Name
sub SetName(itemName as string)
    m.selectedItemName.text = itemName
end sub

'
'Set Selected Overview
sub SetOverview(itemOverview as string)
    m.selectedItemOverview.text = itemOverview
end sub

'
'Set Selected OfficialRating
sub SetOfficialRating(itemOfficialRating as string)
    m.selectedItemOfficialRating.text = itemOfficialRating
end sub

'
'Set Selected ProductionYear
sub SetProductionYear(itemProductionYear)
    m.selectedItemProductionYear.text = itemProductionYear
end sub

'
sub clearFullBleedBackdrop()
    if not isValid(m.libraryBackdropFull) then return

    m.libraryBackdropFull.opacity = 0
    m.libraryBackdropFullTransition.opacity = 0
    m.queuedFullBleedBGUri = string.EMPTY
end sub

'
sub SetFullBleedBackground(backgroundUri as string)
    if not isValid(backgroundUri) or backgroundUri = string.EMPTY
        m.libraryBackdropFull.opacity = 0
        m.libraryBackdropFullTransition.opacity = 0
        m.queuedFullBleedBGUri = string.EMPTY
        return
    end if

    'If a new image is being loaded, or transitioned to, store URL to load next
    if m.libraryBackdropSwapAnimation.state <> "stopped" or m.libraryBackdropFullTransition.loadStatus = "loading"
        m.queuedFullBleedBGUri = backgroundUri
        return
    end if

    m.libraryBackdropFullTransition.uri = backgroundUri
end sub

'
sub applyFocusedItemFullBleedBackdrop(focusedItem as object)
    if not isValid(focusedItem) then return

    if isValidAndNotEmpty(focusedItem.backdropUrl)
        SetFullBleedBackground(focusedItem.backdropUrl)
    else if isChainValid(focusedItem, "id")
        SetFullBleedBackground(api.items.GetImageURL(focusedItem.id, "primary", 0, { "maxHeight": 1080, "maxWidth": 1920, "quality": "90" }))
    end if
end sub

'
'Set Background Image
sub SetBackground(backgroundUri as string)
    if useFullBleedLibraryBackdrop()
        SetFullBleedBackground(backgroundUri)
        return
    end if

    clearFullBleedBackdrop()

    if not isValid(backgroundUri)
        m.backdrop.opacity = 0
    end if

    if not isStringEqual(m.view, "presentation")
        m.newBackdrop.opacity = 0
        m.backdrop.opacity = 0
        return
    end if

    if m.loadedItems = 0
        m.newBackdrop.opacity = 0
        m.backdrop.opacity = 0
        return
    end if

    'If a new image is being loaded, or transitioned to, store URL to load next
    if m.swapAnimation.state <> "stopped" or m.newBackdrop.loadStatus = "loading"
        m.queuedBGUri = backgroundUri
        return
    end if

    m.newBackdrop.uri = backgroundUri
end sub

sub toggleDropdownOptions(runInReverse = false as boolean)
    if isStringEqual(m.view, "presentation")
        m.itemGridMove.keyValue = [[100, 400], [100, 400]]
    else
        m.itemGridMove.keyValue = [[100, 250], [100, 250]]
    end if

    m.dropdownOptionsFade.reverse = runInReverse
    m.dropdownOptionsMove.reverse = runInReverse
    m.itemGridMove.reverse = runInReverse
    m.genreListMove.reverse = runInReverse

    if not isStringEqual(m.toggleDropdownOptionsAnimation.state, AnimationState.RUNNING)
        m.toggleDropdownOptionsAnimation.control = AnimationControl.START
    end if
end sub

'
'Handle new item being focused
sub onItemFocused()
    focusedRow = m.itemGrid.currFocusRow

    ' Handle backdrop for Tags view and TagDetails view
    if isStringEqual(m.view, "Tags") or isStringEqual(m.view, "TagDetails")
        focusedItem = getItemFocused()
        if isValid(focusedItem)
            ' For Tags grid: use the first sample child's backdrop
            ' For TagDetails grid: use the movie's own backdrop
            if isStringEqual(m.view, "Tags") and focusedItem.getChildCount() > 0
                sampleItem = focusedItem.getChild(0)
                if isValid(sampleItem) and isValidAndNotEmpty(sampleItem.backdropUrl)
                    SetFullBleedBackground(sampleItem.backdropUrl)
                end if
            else if isValidAndNotEmpty(focusedItem.backdropUrl)
                SetFullBleedBackground(focusedItem.backdropUrl)
            end if
        end if
    end if

    itemInt = m.itemGrid.itemFocused
    if itemInt = -1
        if isStringEqual(m.view, "presentation")
            itemInt = 0
        else
            ' If no selected item, set background to parent backdrop
            return
        end if
    end if

    m.itemLogo.visible = false
    m.selectedItemName.visible = false

    ' Load more data if focus is within last 5 rows, and there are more items to load
    ' Safety: Don't load more if we have very few rows (common in Tags view)
    if focusedRow >= m.loadedRows - 5 and m.loadeditems < m.loadItemsTask.totalRecordCount and m.loadedRows > 5
        loadMoreData()
    end if

    m.communityRatingGroup.visible = false
    m.criticRatingGroup.visible = false

    if itemInt >= 0 and m.data.getChildCount() > itemInt
        focusedItem = m.data.getChild(itemInt)
    else
        focusedItem = getItemFocused()
    end if
    m.selectedItem = focusedItem

    if useFullBleedLibraryBackdrop()
        applyFocusedItemFullBleedBackdrop(focusedItem)
        return
    end if

    if not isStringEqual(m.view, "presentation")
        return
    end if

    if not isChainValid(focusedItem, "json")
        return
    end if

    itemData = focusedItem.json

    m.star.uri = "pkg:/images/sharp_star_white_18dp.png"

    if m.global.session.user.settings["ui.itemdetail.showRatings"]
        if isValid(itemData.communityRating)
            setFieldText("communityRating", int(itemData.communityRating * 10) / 10)
            m.communityRatingGroup.visible = true
        end if

        if isValid(itemData.CriticRating)
            setFieldText("criticRatingLabel", itemData.criticRating)

            tomato = "pkg:/images/rotten.png"

            if itemData.CriticRating > 60
                tomato = "pkg:/images/fresh.png"
            end if

            m.criticRatingIcon.uri = tomato
            m.criticRatingGroup.visible = true
        end if
    end if

    if isValid(itemData.Name)
        SetName(itemData.Name)
    else
        SetName(string.EMPTY)
    end if

    if isValid(itemData.Overview)
        SetOverview(itemData.Overview)
    else
        SetOverview(string.EMPTY)
    end if

    if isValid(itemData.ProductionYear)
        SetProductionYear(str(itemData.ProductionYear))
    else
        SetProductionYear(string.EMPTY)
    end if

    if type(itemData.RunTimeTicks) = "LongInteger"
        setFieldText("runtime", stri(getRuntime(itemData.RunTimeTicks)) + " mins")
    else
        setFieldText("runtime", string.EMPTY)
    end if

    if isValid(itemData.OfficialRating)
        SetOfficialRating(itemData.OfficialRating)
    else
        SetOfficialRating(string.EMPTY)
    end if

    m.loadLogoTask.itemId = itemData.id
    m.loadLogoTask.itemType = "LogoImage"
    m.loadLogoTask.observeField("content", "LogoImageLoaded")
    m.loadLogoTask.control = "RUN"

    ' Set Background to item backdrop
    if libraryFocusBackdropEnabled()
        if isValidAndNotEmpty(focusedItem.backdropUrl)
            SetBackground(focusedItem.backdropUrl)
        else if isValidAndNotEmpty(focusedItem.posterUrl)
            ' We have a poster image URL, request a new one at a higher resolution
            SetBackground(api.items.GetImageURL(focusedItem.id, "primary", 0, { "maxHeight": 700, "maxWidth": 1100, "quality": "90" }))
        end if
    end if
end sub

function getRuntime(runTimeTicks) as integer
    return round(runTimeTicks / 600000000.0)
end function

function round(f as float) as integer
    ' BrightScript only has a "floor" round
    ' This compares floor to floor + 1 to find which is closer
    m = int(f)
    n = m + 1
    x = abs(f - m)
    y = abs(f - n)
    if y > x
        return m
    else
        return n
    end if
end function

sub setFieldText(field, value)
    node = m.top.findNode(field)
    if node = invalid or value = invalid then return

    ' Handle non strings... Which _shouldn't_ happen, but hey
    if type(value) = "roInt" or type(value) = "Integer"
        value = str(value)
    else if type(value) = "roFloat" or type(value) = "Float"
        value = str(value)
    else if type(value) <> "roString" and type(value) <> "String"
        value = string.EMPTY
    end if

    node.text = value
end sub

'
'When Image Loading Status changes
sub newFullBleedBGLoaded()
    if not isFullBleedLibraryView() or not libraryFocusBackdropEnabled() then return

    if m.libraryBackdropFullTransition.loadStatus = "ready"
        m.libraryBackdropSwapAnimation.control = "start"
    end if
end sub

'
sub swapFullBleedDone()
    if isValid(m.libraryBackdropSwapAnimation) and m.libraryBackdropSwapAnimation.state = "stopped"
        if isFullBleedLibraryView() and libraryFocusBackdropEnabled()
            m.libraryBackdropFull.uri = m.libraryBackdropFullTransition.uri
            m.libraryBackdropFull.opacity = 0.25
            m.libraryBackdropFullTransition.opacity = 0

            if m.libraryBackdropFullTransition.uri <> m.queuedFullBleedBGUri and m.queuedFullBleedBGUri <> string.EMPTY
                SetFullBleedBackground(m.queuedFullBleedBGUri)
                m.queuedFullBleedBGUri = string.EMPTY
            end if
        else
            clearFullBleedBackdrop()
        end if
    end if
end sub

'
'When Image Loading Status changes
sub newBGLoaded()
    if not isStringEqual(m.view, "presentation")
        m.newBackdrop.opacity = 0
        m.backdrop.opacity = 0
        return
    end if

    if m.loadedItems = 0
        m.newBackdrop.opacity = 0
        m.backdrop.opacity = 0
        return
    end if

    'If image load was sucessful, start the fade swap
    if m.newBackdrop.loadStatus = "ready"
        m.swapAnimation.control = "start"
    end if
end sub

'
'Swap Complete
sub swapDone()
    if m.loadedItems = 0
        m.newBackdrop.opacity = 0
        m.backdrop.opacity = 0
        return
    end if

    if not isStringEqual(m.view, "presentation")
        m.newBackdrop.opacity = 0
        m.backdrop.opacity = 0
        return
    end if

    if isValid(m.swapAnimation) and m.swapAnimation.state = "stopped"
        'Set main BG node image and hide transitioning node
        m.backdrop.uri = m.newBackdrop.uri
        m.backdrop.opacity = 1
        m.newBackdrop.opacity = 0

        'If there is another one to load
        if m.newBackdrop.uri <> m.queuedBGUri and m.queuedBGUri <> string.EMPTY
            SetBackground(m.queuedBGUri)
            m.queuedBGUri = string.EMPTY
        end if
    end if
end sub

'
'Load next set of items
sub loadMoreData()
    if isStringEqual(m.loadItemsTask.state, TaskControl.RUN) then return

    startLoadingSpinner(false)
    m.loadItemsTask.startIndex = m.loadedItems
    m.loadItemsTask.control = TaskControl.RUN
end sub

'
'Item Selected
sub onItemSelected()
    ' Check global reentry guard (set by BaseScene on back press)
    if isValid(m.global.reentryGuardActive) and m.global.reentryGuardActive = true
        print "[REENTRY_GUARD] VisualLibraryScene blocking selection due to global guard"
        return
    end if

    ' Check local reentry guard
    if m.reentryGuardActive = true
        return
    end if

    item = m.itemGrid.content.getChild(m.itemGrid.itemSelected)
    if not isValid(item) then return

    print "[SELECT] item.type=" + item.type + " item.title=" + item.title + " m.view=" + m.view

    if isStringEqual(m.view, "Tags")
        m.tagsExitRestoreTitle = item.title
        m.tagsExitRestoreIndex = m.itemGrid.itemFocused
        if m.tagsExitRestoreIndex < 0
            m.tagsExitRestoreIndex = m.itemGrid.itemSelected
        end if
        m.selectedTag = item.title
        enterTagDetails(item.title)
    else
        m.top.selectedItem = item
    end if
end sub

' Transition into Tag Details view for a specific tag
sub enterTagDetails(tagName as string)
    m.view = "TagDetails"
    m.topBar.visible = false
    m.tagTitle.text = tagName
    m.tagTitle.visible = true
    m.selectedTag = tagName

    ' Reset grid
    m.loadedRows = 0
    m.loadedItems = 0
    m.data = CreateObject("roSGNode", "ContentNode")
    m.itemGrid.content = m.data
    m.itemGrid.vertFocusAnimationStyle = "floatingFocus"

    ' Apply full-bleed grid layout
    m.itemGrid.translation = [100, 0]
    m.itemGrid.numRows = 5
    m.selectedItemOverview.visible = false
    m.selectedItemName.visible = false
    m.infoGroup.visible = false
    m.newBackdrop.opacity = 0

    loadTagDetailsItems()
end sub

' Load movies filtered by the selected tag â€” completely bypasses loadInitialItems
sub loadTagDetailsItems()
    if not isValidAndNotEmpty(m.selectedTag)
        print "[TAG_DETAILS] selectedTag is empty, aborting"
        return
    end if

    print "[TAG_DETAILS] Loading movies with tag='" + m.selectedTag + "' parentId=" + m.top.parentItem.Id

    m.loadItemsTask.control = TaskControl.STOP
    startLoadingSpinner(false)

    ' Directly configure the task â€” do NOT call loadInitialItems()
    m.loadItemsTask.view = string.EMPTY ' use default Items endpoint
    m.loadItemsTask.itemId = m.top.parentItem.Id
    m.loadItemsTask.itemType = m.top.mediaType
    m.loadItemsTask.sortField = "SortName"
    m.loadItemsTask.sortAscending = true
    m.loadItemsTask.filter = "All"
    m.loadItemsTask.filterOptions = {}
    m.loadItemsTask.startIndex = 0
    m.loadItemsTask.studioIds = string.EMPTY
    m.loadItemsTask.genreIds = string.EMPTY
    m.loadItemsTask.tagIds = string.EMPTY
    m.loadItemsTask.searchTerm = string.EMPTY
    m.loadItemsTask.recursive = true
    m.loadItemsTask.tags = m.selectedTag ' THE critical filter
    m.loadItemsTask.passToItem = { libraryID: m.top.parentItem.id }

    m.loadItemsTask.control = TaskControl.RUN
end sub

function findTagGridIndexByTitle(contentRoot as object, titleSearch as string) as integer
    if not isValid(contentRoot) or not isValidAndNotEmpty(titleSearch) then return -1
    want = LCase(titleSearch.trim())
    n = contentRoot.getChildCount()
    for i = 0 to n - 1
        ch = contentRoot.getChild(i)
        if isValid(ch) and isValidAndNotEmpty(ch.title)
            if LCase(ch.title.trim()) = want
                return i
            end if
        end if
    end for
    return -1
end function

sub ensureTagsRestoreTimer()
    if isValid(m.tagsRestoreTimer) then return
    m.tagsRestoreTimer = createObject("roSGNode", "Timer")
    m.tagsRestoreTimer.repeat = false
    m.tagsRestoreTimer.duration = 0.12
    m.tagsRestoreTimer.observeField("fire", "onTagsRestoreTimerFire")
    m.top.appendChild(m.tagsRestoreTimer)
end sub

' Defer jump until MarkupGrid has applied content (same-frame jump often no-ops)
sub scheduleTagsGridRestoreFocus()
    if not isStringEqual(m.view, "Tags") then return
    if (not isValidAndNotEmpty(m.tagsExitRestoreTitle)) and m.tagsExitRestoreIndex < 0
        return
    end if
    ensureTagsRestoreTimer()
    m.tagsRestoreTimer.control = "stop"
    m.tagsRestoreTimer.control = "start"
end sub

sub onTagsRestoreTimerFire()
    if not isValid(m.tagsRestoreTimer) then return
    m.tagsRestoreTimer.control = "stop"

    if not isStringEqual(m.view, "Tags")
        m.tagsExitRestoreTitle = ""
        m.tagsExitRestoreIndex = -1
        return
    end if
    if not isValid(m.itemGrid) or not isValid(m.data)
        m.tagsExitRestoreTitle = ""
        m.tagsExitRestoreIndex = -1
        return
    end if

    idx = -1
    if isValidAndNotEmpty(m.tagsExitRestoreTitle)
        idx = findTagGridIndexByTitle(m.data, m.tagsExitRestoreTitle)
    end if
    if idx < 0 and m.tagsExitRestoreIndex >= 0 and m.tagsExitRestoreIndex < m.data.getChildCount()
        idx = m.tagsExitRestoreIndex
    end if

    if idx >= 0
        m.itemGrid.jumpToItem = idx
        m.itemGrid.itemFocused = idx
        m.itemGrid.setFocus(true)
        grp = m.global.sceneManager.callFunc("getActiveScene")
        if isValid(grp) then grp.lastFocus = m.itemGrid
    end if

    m.tagsExitRestoreTitle = ""
    m.tagsExitRestoreIndex = -1
end sub

' Go back to the Tags grid from TagDetails â€” uses ContentNode cache for instant restore
sub loadTagsItems()
    print "[TAGS] Returning to Tags grid"
    m.loadItemsTask.control = TaskControl.STOP
    m.loadedRows = 0
    m.loadedItems = 0

    ' Reuse cached ContentNode for instant restore (no GC issues with re-parenting)
    if isValid(m.cachedTagsContentNode)
        m.data = m.cachedTagsContentNode
        m.itemGrid.content = m.data
        m.loadedItems = m.data.getChildCount()
        m.itemGrid.opacity = 1.0
        m.itemGrid.visible = true
        m.itemGrid.vertFocusAnimationStyle = "fixed"

        m.itemGrid.setFocus(true)
        group = m.global.sceneManager.callFunc("getActiveScene")
        if isValid(group) then group.lastFocus = m.itemGrid

        scheduleTagsGridRestoreFocus()

        stopLoadingSpinner()
        return
    end if

    ' No cache â€” fetch from server
    startLoadingSpinner(false)
    if isValid(m.loadingSpinner)
        m.loadingSpinner.visible = true
        m.loadingSpinner.control = "start"
    end if
    m.data = CreateObject("roSGNode", "ContentNode")
    m.itemGrid.content = m.data
    m.loadItemsTask.view = "Tags"
    m.loadItemsTask.itemId = m.top.parentItem.Id
    m.loadItemsTask.itemType = string.EMPTY
    m.loadItemsTask.sortField = "SortName"
    m.loadItemsTask.sortAscending = true
    m.loadItemsTask.filter = "All"
    m.loadItemsTask.filterOptions = {}
    m.loadItemsTask.startIndex = 0
    m.loadItemsTask.studioIds = string.EMPTY
    m.loadItemsTask.genreIds = string.EMPTY
    m.loadItemsTask.tagIds = string.EMPTY
    m.loadItemsTask.tags = string.EMPTY
    m.loadItemsTask.searchTerm = string.EMPTY
    m.loadItemsTask.recursive = false
    m.loadItemsTask.passToItem = { libraryID: m.top.parentItem.id }
    m.itemGrid.vertFocusAnimationStyle = "fixed"
    m.loadItemsTask.control = TaskControl.RUN
end sub

'
'Returns Focused Item
function getItemFocused()
    if m.itemGrid.isinFocusChain() and isValid(m.itemGrid.itemFocused)
        return m.itemGrid.content.getChild(m.itemGrid.itemFocused)
    else if m.genreList.isinFocusChain() and isValid(m.genreList.rowItemFocused)
        return m.genreList.content.getChild(m.genreList.rowItemFocused[0]).getChild(m.genreList.rowItemFocused[1])
    end if
    return invalid
end function

'
'Genre Item Selected
sub onGenreItemSelected()
    m.top.selectedItem = m.genreList.content.getChild(m.genreList.rowItemSelected[0]).getChild(m.genreList.rowItemSelected[1])
end sub

'
'Genre Item Focused
sub onGenreItemFocused()
    focusedRow = m.genreList.currFocusRow

    if m.genreList.isinFocusChain()
        if focusedRow = 0
            if m.dropdownOptions.opacity < 1
                toggleDropdownOptions(true)
            end if
        else if focusedRow > 0
            if m.dropdownOptions.opacity > 0
                toggleDropdownOptions(false)
            end if
        end if
    end if
end sub

sub onReentryGuardExpired()
    m.reentryGuardActive = false
    if m.reentryGuardTimer <> invalid
        m.reentryGuardTimer.unobserveField("fire")
        m.reentryGuardTimer = invalid
    end if
end sub

sub onGenreRowBackdrop()
    if useFullBleedLibraryBackdrop() and (isStringEqual(m.view, "Genres") or isStringEqual(m.view, "Tags"))
        applyFocusedItemFullBleedBackdrop(getItemFocused())
    end if
end sub

sub processDropdownState(searchTerm as string)
    if not isStringEqual(searchTerm, string.EMPTY)
        resetDropdownsToDefaultState()
        setDropdownDisabledState(true)
        return
    end if

    setDropdownDisabledState(false)
end sub

sub setDropdownDisabledState(disabledState = false as boolean)
    m.sortButton.disabled = disabledState
    m.sortOrderButton.disabled = disabledState
    m.filterButton.disabled = disabledState
end sub

sub resetDropdownsToDefaultState()
    m.filter = "All"
    m.filterOptions = {}
    if isStringEqual(getCollectionType(), ItemType.BOXSET)
        m.sortField = "PremiereDate,SortName"
    else if isStringEqual(getCollectionType(), ItemType.MYLIST)
        m.sortField = "OrderAdded"
    else
        m.sortField = "SortName"
    end if
    m.sortAscending = true

    ' Reset view to defaults
    set_user_setting(getTabSettingsKey() + ".sortField", m.sortField)
    set_user_setting(getTabSettingsKey() + ".sortAscending", "true")
    set_user_setting(getTabSettingsKey() + ".filter", m.filter)
    set_user_setting(getTabSettingsKey() + ".filterOptions", FormatJson(m.filterOptions))

    if not isStringEqual(m.view, "Genres") and not isStringEqual(m.view, "Tags")
        set_user_setting(`display.${m.top.mediaType}library.defaultview`, m.view)
    end if

    m.getFiltersTask.control = "RUN"
end sub

sub onSearchTermChanged()
    if m.voiceBox.hasField("hintText")
        m.voiceBox.hintText = m.top.searchTerm = string.EMPTY ? tr("Press OK to type") : m.top.searchTerm
    end if

    onVoiceEnabledChange()

    if isStringEqual(m.loadItemsTask.searchTerm, m.top.searchTerm) then return

    setSearchBackground(SearchButtonState.INACTIVE)

    processDropdownState(m.top.searchTerm)

    if m.bypassSearchEvent
        m.bypassSearchEvent = false
        return
    end if

    m.loadedRows = 0
    m.loadedItems = 0

    m.data = CreateObject("roSGNode", "ContentNode")
    m.itemGrid.content = m.data

    m.genreData = CreateObject("roSGNode", "ContentNode")
    m.genreList.content = m.genreData

    loadInitialItems()
end sub

sub alphaSelectedChanged()
    ' Prevent voicebox change double firing
    if m.voiceBox.hasField("text") and m.voiceBox.text = string.EMPTY
        ' Allow user to toggle by clicking letter twice
        if isStringEqual(m.loadItemsTask.nameStartsWith, m.top.alphaSelected)
            m.top.alphaSelected = string.EMPTY
        end if
    end if

    m.loadItemsTask.control = TaskControl.STOP
    m.loadedRows = 0
    m.loadedItems = 0

    m.data = CreateObject("roSGNode", "ContentNode")
    m.itemGrid.content = m.data

    m.genreData = CreateObject("roSGNode", "ContentNode")
    m.genreList.content = m.genreData

    m.loadItemsTask.nameStartsWith = m.top.alphaSelected
    
    ' Set bypass flag so onSearchTermChanged doesn't trigger a second loadInitialItems()
    m.bypassSearchEvent = true
    if m.voiceBox.hasField("text") then m.voiceBox.text = string.EMPTY
    m.top.searchTerm = string.EMPTY
    
    loadInitialItems()
end sub

sub unfocusAllButtons()
    setSearchBackground(SearchButtonState.INACTIVE)
    m.sortButton.focus = false
    m.sortOrderButton.focus = false
    m.filterButton.focus = false
    m.viewButton.focus = false
end sub

sub onvoiceFilter()
    if not m.voiceBox.hasField("text") or not isValidAndNotEmpty(m.voiceBox.text) then return

    unfocusAllButtons()

    if m.voiceBox.hasField("text")
        if isStringEqual(m.voiceBox.text.trim(), "reset search") then m.voiceBox.text = string.EMPTY
        if isStringEqual(m.voiceBox.text.trim(), "clear search") then m.voiceBox.text = string.EMPTY
    end if

    if m.voiceBox.hasField("hintText") and m.voiceBox.hasField("text")
        m.voiceBox.hintText = m.voiceBox.text
    end if

    ' If user searched for a letter, selected it from the alpha menu
    if m.voiceBox.hasField("text") and m.voiceBox.text.len() = 1
        alphaMenu = m.top.findNode("alphaMenu")
        intConversion = m.voiceBox.text.ToInt() ' non numeric input returns as 0

        if m.voiceBox.text = "0" or (isValid(intConversion) and intConversion <> 0)
            alphaMenu.jumpToItem = 0
        else
            ' loop through each option until we find a match
            for i = 1 to alphaMenu.numRows - 1
                alphaMenuOption = alphaMenu.content.getChild(i)
                if m.voiceBox.hasField("text") and isStringEqual(alphaMenuOption.TITLE, m.voiceBox.text)
                    alphaMenu.jumpToItem = i
                    exit for
                end if
            end for
        end if

        m.top.alphaSelected = m.voiceBox.text
        return
    end if

    if m.searchButtonDisabled
        m.itemGrid.setFocus(m.itemGrid.opacity = 1)
        m.genreList.setFocus(m.genreList.opacity = 1)
        return
    end if

    if m.voiceBox.hasField("text")
        m.top.searchTerm = m.voiceBox.text.trim()
    end if
end sub

'
'Check if options updated and any reloading required
sub onOptionsVisibleChange()
    if m.options.visible then return

    reload = false

    ' Nothing changed
    if isStringEqual(m.options.filter, m.filter)
        if AssocArrayEqual(m.options.filterOptions, m.filterOptions)
            m.filterButton.focus = true
            m.filterButton.setfocus(true)
            return
        end if
    end if

    if m.options.filter <> m.filter
        m.filter = m.options.filter
        reload = true
        set_user_setting(getTabSettingsKey() + ".filter", m.options.filter)
    end if

    if not isValid(m.options.filterOptions)
        m.filterOptions = {}
    end if

    if not AssocArrayEqual(m.options.filterOptions, m.filterOptions)
        m.filterOptions = m.options.filterOptions
        reload = true
        set_user_setting(getTabSettingsKey() + ".filterOptions", FormatJson(m.options.filterOptions))
    end if

    if isMovieLibraryView()
        buildTopTabs([])
    end if

    if reload
        m.loadedRows = 0
        m.loadedItems = 0
        m.data = CreateObject("roSGNode", "ContentNode")
        m.itemGrid.content = m.data
        loadInitialItems()
    end if

    m.filterButton.focus = false

    m.itemGrid.setFocus(m.itemGrid.opacity = 1)
    m.genreList.setFocus(m.genreList.opacity = 1)

    group = m.global.sceneManager.callFunc("getActiveScene")
    group.lastFocus = m.itemGrid.opacity = 1 ? m.itemGrid : m.genreList
end sub

sub onSortChange()
    m.global.sceneManager.unobserveFieldScoped("returnData")
    sortChoice = m.global.sceneManager.returnData

    if not isChainValid(sortChoice, "name") then return
    if isStringEqual(sortChoice.LookupCI("name"), m.sortField) then return

    m.sortButton.focus = false
    m.itemGrid.setFocus(m.itemGrid.opacity = 1)
    m.genreList.setFocus(m.genreList.opacity = 1)

    m.sortField = sortChoice.LookupCI("name")

    m.sortAscending = true

    set_user_setting(getTabSettingsKey() + ".sortField", m.sortField)

    m.loadedRows = 0
    m.loadedItems = 0
    m.data = CreateObject("roSGNode", "ContentNode")
    m.itemGrid.content = m.data
    loadInitialItems()
end sub

sub onViewChange()
    m.global.sceneManager.unobserveFieldScoped("returnData")
    viewChoice = m.global.sceneManager.returnData
    if not isChainValid(viewChoice, "name") then return
    if isStringEqual(viewChoice.LookupCI("name"), m.view) then return

    m.viewButton.focus = false

    ' If we're moving to or from the episodes view, we must recreate the item grid to change the itemComponentName property
    if inArray([m.view, viewChoice.LookupCI("name")], "Episodes")
        m.top.removeChild(m.itemGrid)
        ' The slide up animation will fail if the new itemGrid ID isn't unique /shrug
        m.itemGridCounter++
        createItemGrid(`itemGrid${m.itemGridCounter}`)
    end if

    m.view = viewChoice.LookupCI("name")

    if isMovieLibraryView()
        buildTopTabs([])
    end if

    set_user_setting(getTabSettingsKey() + ".landing", m.view)

    ' Reset any filtering or search terms
    m.bypassSearchEvent = true
    m.top.searchTerm = string.EMPTY
    m.top.alphaSelected = string.EMPTY
    m.loadItemsTask.NameStartsWith = " "
    m.loadItemsTask.searchTerm = string.EMPTY
    m.filter = "All"
    m.filterOptions = {}
    if isStringEqual(getCollectionType(), ItemType.BOXSET)
        m.sortField = "PremiereDate,SortName"
    else if isStringEqual(getCollectionType(), ItemType.MYLIST)
        m.sortField = "OrderAdded"
    else
        m.sortField = "SortName"
    end if
    m.sortAscending = true

    ' Reset view to defaults
    set_user_setting(getTabSettingsKey() + ".sortField", m.sortField)
    set_user_setting(getTabSettingsKey() + ".sortAscending", "true")
    set_user_setting(getTabSettingsKey() + ".filter", m.filter)
    set_user_setting(getTabSettingsKey() + ".filterOptions", FormatJson(m.filterOptions))

    if not isStringEqual(m.view, "Genres") and not isStringEqual(m.view, "Tags")
        set_user_setting(`display.${m.top.mediaType}library.defaultview`, m.view)
    end if

    m.getFiltersTask.control = "RUN"

    m.loadedRows = 0
    m.loadedItems = 0

    ' JellyVibe: Keep focus on tabs after selection so the user can continue looping/scrolling
    ' m.itemGrid.setFocus(m.itemGrid.opacity = 1)
    ' m.genreList.setFocus(m.genreList.opacity = 1)

    m.data = CreateObject("roSGNode", "ContentNode")
    m.itemGrid.content = m.data
    loadInitialItems()
end sub

sub createItemGrid(itemGridID = "itemGrid" as string)
    m.itemGrid = createObject("rosgnode", "MarkupGrid")
    m.itemGrid.focusBitmapBlendColor = chainLookupReturn(m.global.session, "user.settings.colorCursor", ColorPalette.HIGHLIGHT)
    ' Match XML grid + GridItemSmall: item draws focusOutline; avoid default MarkupGrid overlay
    m.itemGrid.drawFocusFeedback = false
    m.itemGrid.clippingRect = "[-100, -100, 1920, 1080]"
    m.itemGrid.translation = [100, 0]

    if isStringEqual(m.view, "Episodes")
        m.itemGrid.itemComponentName = "GridItemMedium"
    else
        m.itemGrid.itemComponentName = "GridItemSmall"
    end if
    updateGridFocusFeedbackMode()

    if isStringEqual(m.view, "presentation")
        m.itemGrid.vertFocusAnimationStyle = "fadingFocus"
    else
        m.itemGrid.vertFocusAnimationStyle = "fixed"
    end if

    m.top.insertChild(m.itemGrid, 1)

    m.itemGridMove.fieldToInterp = `${m.itemGrid.id}.translation`
end sub

sub onSortOrderChange()
    m.global.sceneManager.unobserveFieldScoped("returnData")
    sortOrderChoice = m.global.sceneManager.returnData
    if not isChainValid(sortOrderChoice, "name") then return
    if m.sortAscending = isStringEqual(sortOrderChoice.LookupCI("name"), "ascending") then return

    m.sortOrderButton.focus = false
    m.itemGrid.setFocus(m.itemGrid.opacity = 1)
    m.genreList.setFocus(m.genreList.opacity = 1)

    m.sortAscending = isStringEqual(sortOrderChoice.LookupCI("name"), "Ascending")
    if isValid(m.sortOrderButton)
        m.sortOrderButton.iconUri = m.sortAscending ? "pkg:/images/icons/up_white.png" : "pkg:/images/icons/down_white.png"
    end if

    set_user_setting(getTabSettingsKey() + ".sortAscending", m.sortAscending.toStr())

    m.loadedRows = 0
    m.loadedItems = 0
    m.data = CreateObject("roSGNode", "ContentNode")
    m.itemGrid.content = m.data
    loadInitialItems()
end sub

' Using the user's cursor position, determine which dropdown is above them
function getOverhangingButton()
    if m.itemGrid.isinFocusChain()
        if m.itemGrid.numColumns = 4
            shortButtonList = [m.voiceBox, m.sortButton, m.filterButton, m.viewButton]
            return shortButtonList[m.itemGrid.currFocusColumn]
        end if

        buttonList = [m.voiceBox, m.sortButton, m.sortOrderButton, m.filterButton, m.viewButton]

        columnDisplacement = (m.itemGrid.numColumns / buttonList.count())

        calculatedButtonIndex = CInt(((m.itemGrid.currFocusColumn + 1) / columnDisplacement) - 1)
        if calculatedButtonIndex < 0 then calculatedButtonIndex = 0
        if calculatedButtonIndex >= buttonList.count() then calculatedButtonIndex = buttonList.count() - 1
        return buttonList[calculatedButtonIndex]
    end if

    if m.genreList.isinFocusChain()
        if m.genreList.currFocusColumn <= 0 then return m.voiceBox
        if m.genreList.currFocusColumn <= 2 then return m.sortButton
        if m.genreList.currFocusColumn <= 3 then return m.sortOrderButton
        if m.genreList.currFocusColumn <= 5 then return m.filterButton
        return m.viewButton
    end if

    return m.voiceBox
end function

sub onLibrarySettingsSelected()
    m.global.sceneManager.callFunc("librarySettingDialog", tr("Library Settings"))
end sub

function onKeyEvent(key as string, press as boolean) as boolean
    if not press then return false

    if isStringEqual(key, KeyCode.BACK)
        if isStringEqual(m.view, "TagDetails")
            ' If global reentry guard is active, we just returned from a child scene.
            ' Consume back but stay in TagDetails â€” user must press back again to exit.
            if isValid(m.global.reentryGuardActive) and m.global.reentryGuardActive = true
                m.itemGrid.setFocus(true)
                return true
            end if

            ' Exit Tag Details and return to Tags grid
            m.view = "Tags"
            m.topBar.visible = true
            m.tagTitle.visible = false
            m.selectedTag = ""

            ' Restore Tags grid layout
            m.itemGrid.translation = [100, 0]
            m.itemGrid.numRows = 5
            m.itemGrid.vertFocusAnimationStyle = "fixed"
            m.selectedItemOverview.visible = false
            m.selectedItemName.visible = false
            m.infoGroup.visible = false

            ' Use dedicated loader â€” not loadInitialItems() which would reset view
            loadTagsItems()
            return true
        end if
    end if

    if handleTopUtilityNavigation(key) then return true
    if handleCategoryTabDirectionalNav(key) then return true

    ' Ã¢â€â‚¬Ã¢â€â‚¬ Alpha menu vertical nav Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
    if isStringEqual(key, KeyCode.DOWN)
        if m.overviewGroup.hasFocus()
            m.overviewFocus.opacity = 0
            m.itemGrid.setFocus(true)
            return true
        end if

        if m.alphaMenu.isinFocusChain()
            if m.alphaMenu.itemFocused = m.alphaMenu.numRows - 1
                ' Wrap or move somewhere else?
                return true
            end if
        end if

        ' Down from top tabs to content grid
        if m.categoryTabs.isinFocusChain()
            return focusGridFromTopMenu()
        end if

        ' Intercept DOWN from sidebar icon buttons to move to next button in LayoutGroup
        if m.voiceBoxButton.isinFocusChain()
            m.sortButton.setFocus(true)
            return true
        else if m.sortButton.isinFocusChain()
            m.sortOrderButton.setFocus(true)
            return true
        else if m.sortOrderButton.isinFocusChain()
            m.filterButton.setFocus(true)
            return true
        else if m.filterButton.isinFocusChain()
            m.viewButton.setFocus(true)
            return true
        else if m.viewButton.isinFocusChain()
            m.librarySettingsButton.setFocus(true)
            return true
        end if

        if m.librarySettingsButton.isinFocusChain()
            if m.loadedItems = 0 then return true
            m.itemGrid.setFocus(m.itemGrid.opacity = 1)
            m.genreList.setFocus(m.genreList.opacity = 1)
            group = m.global.sceneManager.callFunc("getActiveScene")
            group.lastFocus = m.itemGrid.opacity = 1 ? m.itemGrid : m.genreList
            return true
        end if
    end if

    if isStringEqual(key, KeyCode.UP)
        if m.overviewGroup.hasFocus()
            m.overviewFocus.opacity = 0
            m.categoryTabs.setFocus(true)
            group = m.global.sceneManager.callFunc("getActiveScene")
            group.lastFocus = m.categoryTabs
            return true
        end if

        if m.alphaMenu.isinFocusChain()
            if m.alphaMenu.itemFocused = 0
                ' Move up from alpha to navigation menu
                focusCategoryTabsAtEnd()
                return true
            end if
        end if

        if m.librarySettingsButton.isinFocusChain()
            m.viewButton.setFocus(true)
            return true
        else if m.viewButton.isinFocusChain()
            m.filterButton.setFocus(true)
            return true
        else if m.filterButton.isinFocusChain()
            m.sortOrderButton.setFocus(true)
            return true
        else if m.sortOrderButton.isinFocusChain()
            m.sortButton.setFocus(true)
            return true
        else if m.sortButton.isinFocusChain()
            m.voiceBoxButton.setFocus(true)
            return true
        end if

        ' Up from grid row 0 or top icon Ã¢â€ â€™ focus overview in presentation mode, or categoryTabs
        if m.itemGrid.isinFocusChain() or m.genreList.isinFocusChain() or m.voiceBoxButton.isinFocusChain()
            if isStringEqual(m.view, "presentation")
                m.overviewFocus.opacity = 0.25
                m.overviewGroup.setFocus(true)
                group = m.global.sceneManager.callFunc("getActiveScene")
                group.lastFocus = m.overviewGroup
                return true
            end if


            m.categoryTabs.setFocus(true)
            group = m.global.sceneManager.callFunc("getActiveScene")
            group.lastFocus = m.categoryTabs
            return true
        end if
    end if

    ' Ã¢â€â‚¬Ã¢â€â‚¬ Right-side icon sidebar OK handling Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
    ' LibraryFilterDialog only has filterMenu Ã¢â‚¬â€ sort/view use radioDialog like MusicLibraryView.
    if isStringEqual(key, KeyCode.OK)
        if isValid(m.voiceBoxButton) and m.voiceBoxButton.isinFocusChain()
            if m.searchButtonDisabled then return false
            m.global.sceneManager.callFunc("keyboardDialog", "searchLibrary", tr("Search this library"), [""], [tr("Search")], m.top.searchTerm, m.top.parentItem.Id)
            return true
        end if

        if m.librarySettingsButton.isinFocusChain()
            onLibrarySettingsSelected()
            return true
        end if

        if m.overviewGroup.hasFocus()
            createFullOverviewDialog()
            return true
        end if

        if m.sortButton.isinFocusChain()
            if m.sortButton.disabled then return false
            if not isValid(m.options) or not isValid(m.options.options) or not isValid(m.options.options.sort) then return false
            sortData = { data: m.options.options.sort }
            m.global.sceneManager.callFunc("radioDialog", tr("Sort By"), sortData)
            m.global.sceneManager.observeFieldScoped("returnData", "onSortChange")
            return true
        end if

        if m.sortOrderButton.isinFocusChain()
            if m.sortOrderButton.disabled then return false
            sortOrderData = {
                data: [
                    { Title: tr("Ascending"), Name: "ascending", Track: { description: tr("Ascending") } },
                    { Title: tr("Descending"), Name: "descending", Track: { description: tr("Descending") } }
                ]
            }
            if m.sortAscending
                sortOrderData.data[0].selected = true
            else
                sortOrderData.data[1].selected = true
            end if
            m.global.sceneManager.callFunc("radioDialog", tr("Sort Order"), sortOrderData)
            m.global.sceneManager.observeFieldScoped("returnData", "onSortOrderChange")
            return true
        end if

        if m.filterButton.isinFocusChain()
            if m.filterButton.disabled then return false
            if not isValid(m.options) then return false
            m.options.visible = true
            filterMenu = m.options.findNode("filterMenu")
            if isValid(filterMenu) then filterMenu.setFocus(true)
            group = m.global.sceneManager.callFunc("getActiveScene")
            group.lastFocus = m.options
            return true
        end if

        if isValid(m.viewButton) and m.viewButton.isinFocusChain()
            if not isValid(m.options) or not isValid(m.options.options) or not isValid(m.options.options.views) then return false
            viewData = { data: m.options.options.views }
            m.global.sceneManager.callFunc("radioDialog", tr("TAB_VIEW"), viewData)
            m.global.sceneManager.observeFieldScoped("returnData", "onViewChange")
            return true
        end if

        ' Top tab OK
        if m.categoryTabs.isinFocusChain()
            onCategorySelected()
            return true
        end if

    end if

    ' Ã¢â€â‚¬Ã¢â€â‚¬ Right-side icon sidebar LEFT (back to grid) Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
    if m.rightIcons.isinFocusChain()
        if isStringEqual(key, KeyCode.LEFT)
            m.itemGrid.setFocus(m.itemGrid.opacity = 1)
            m.genreList.setFocus(m.genreList.opacity = 1)
            group = m.global.sceneManager.callFunc("getActiveScene")
            group.lastFocus = m.itemGrid.opacity = 1 ? m.itemGrid : m.genreList
            return true
        end if
    end if

    ' Ã¢â€â‚¬Ã¢â€â‚¬ Grid RIGHT Ã¢â€ â€™ right icon sidebar Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
    if isStringEqual(key, KeyCode.RIGHT)
        if m.itemGrid.isinFocusChain()
            ' Move to sidebar if at the right edge of the grid OR at the last item
            isLastColumn = isValid(m.itemGrid) and (m.itemGrid.currFocusColumn >= m.itemGrid.numColumns - 1)
            isLastItem = isValid(m.itemGrid) and (m.itemGrid.itemFocused >= m.data.getChildCount() - 1)

            if isLastColumn or isLastItem
                m.sortButton.setFocus(true)
                group = m.global.sceneManager.callFunc("getActiveScene")
                group.lastFocus = m.sortButton
                return true
            end if
            return false ' Let grid handle internal navigation
        else if m.genreList.isinFocusChain()
            ' For RowList, move to sidebar if at the end of the row
            ri = m.genreList.rowItemFocused
            if isValid(ri)
                rowNode = m.genreList.content.getChild(ri[0])
                if isValid(rowNode) and ri[1] >= rowNode.getChildCount() - 1
                    m.sortButton.setFocus(true)
                    group = m.global.sceneManager.callFunc("getActiveScene")
                    group.lastFocus = m.sortButton
                    return true
                end if
            end if
            return false
        end if

        ' Right from alpha Ã¢â€ â€™ focus grid
        if m.alpha.isinFocusChain()
            m.top.alphaActive = false
            m.alphaMenu.setFocus(false)
            if m.loadedItems = 0
                m.sortButton.setFocus(true)
                group = m.global.sceneManager.callFunc("getActiveScene")
                group.lastFocus = m.sortButton
            else
                m.itemGrid.setFocus(m.itemGrid.opacity = 1)
                m.genreList.setFocus(m.genreList.opacity = 1)
                group = m.global.sceneManager.callFunc("getActiveScene")
                group.lastFocus = m.itemGrid.opacity = 1 ? m.itemGrid : m.genreList
                ' Ensure we reset scroll direction if needed
                m.itemGrid.scrollDirection = "vertical"
            end if
            return true
        end if
    end if

    ' Ã¢â€â‚¬Ã¢â€â‚¬ Grid LEFT Ã¢â€ â€™ alpha bar Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
    if isStringEqual(key, KeyCode.LEFT)
        if m.itemGrid.isinFocusChain()
            if m.itemGrid.currFocusColumn = 0
                alphaDisplayed = m.alpha.callFunc("getDisplay")
                if alphaDisplayed
                    m.top.alphaActive = true
                    m.itemGrid.setFocus(false)
                    m.alphaMenu.setFocus(true)
                    group = m.global.sceneManager.callFunc("getActiveScene")
                    group.lastFocus = m.alphaMenu
                    return true
                end if
                ' If no alpha, just stay on grid (or do nothing)
                return true
            end if
            return false ' Let grid handle internal navigation
        else if m.genreList.isinFocusChain()
            ' For RowList, we only move to alpha if at the beginning of the row
            ' RowList doesn't expose currFocusColumn easily, but let's assume it's at index 0
            ri = m.genreList.rowItemFocused
            if isValid(ri) and ri[1] = 0
                alphaDisplayed = m.alpha.callFunc("getDisplay")
                if alphaDisplayed
                    m.top.alphaActive = true
                    m.genreList.setFocus(false)
                    m.alphaMenu.setFocus(true)
                    group = m.global.sceneManager.callFunc("getActiveScene")
                    group.lastFocus = m.alphaMenu
                    return true
                end if
                return true
            end if
            return false
        end if
    end if

    ' Ã¢â€â‚¬Ã¢â€â‚¬ Back key Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
    if isStringEqual(key, KeyCode.BACK)
        if m.itemGrid.isinFocusChain() or m.genreList.isinFocusChain()
            gridComponent = m.itemGrid.isinFocusChain() ? m.itemGrid : m.genreList
            if gridComponent.itemFocused = 0
                reclaimResources()
                m.global.sceneManager.callfunc("popScene")
                return true
            end if
            gridComponent.jumpToItem = 0
            return true
        end if
        reclaimResources()
        m.global.sceneManager.callfunc("popScene")
        return true
    end if

    ' Ã¢â€â‚¬Ã¢â€â‚¬ Quick play Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬
    if isStringEqual(key, KeyCode.PLAY)
        itemToPlay = getItemFocused()
        if isValid(itemToPlay)
            if isStringEqual(ItemType.PHOTO, chainLookupReturn(itemToPlay, "type", string.EMPTY))
                m.itemGrid.itemSelected = m.itemGrid.itemFocused
                return true
            end if
            m.top.quickPlayNode = itemToPlay
            return true
        end if
    end if

    if isStringEqual(key, KeyCode.OPTIONS)
        m.showOptionMenu = true
        focusedItem = getItemFocused()
        if not isValid(focusedItem) then return false
        m.loadItemsTask1.itemId = focusedItem.LookupCI("id")
        m.loadItemsTask1.observeField("content", "onItemDataLoaded")
        m.loadItemsTask1.itemsToLoad = "metaData"
        m.loadItemsTask1.control = TaskControl.RUN
        return true
    end if

    return false
end function


sub onMyListLoaded()
    isInMyListData = m.isInMyListTask.content
    m.isInMyListTask.unobserveField("content")
    m.isInMyListTask.content = []
    m.isInMyListTask.control = TaskControl.STOP

    if not isValidAndNotEmpty(isInMyListData) then return

    focusedItem = getItemFocused()
    if not isValid(focusedItem) then return

    dialogData = []

    if inArray([ItemType.BOXSET, CollectionType.BOXSETS], getCollectionType())
        dialogData.push(tr("Shuffle Play Collection"))
    end if

    myListOption = isInMyListData[0] ? tr("Remove From My List") : tr("Add To My List")
    dialogData.push(myListOption)

    dialogData.push(m.favoritesOptionText)
    dialogData.push(tr("Add To Playlist"))
    paramData = {
        id: focusedItem.LookupCI("id")
    }

    if isChainValid(focusedItem, "watched")
        if focusedItem.watched
            dialogData.push(tr("Mark As Unplayed"))
        else
            dialogData.push(tr("Mark As Played"))
        end if
    end if

    if inArray([ItemType.EPISODE, ItemType.SEASON], focusedItem.LookupCI("type"))
        paramData.SeasonId = focusedItem.json.LookupCI("SeasonId")
        paramData.SeriesId = focusedItem.json.LookupCI("SeriesId")
    end if

    optionsTitle = tr("Options")
    if focusedItem.LookupCI("title") <> invalid then optionsTitle = focusedItem.LookupCI("title")
    m.global.sceneManager.callFunc("optionDialog", "libraryitem", optionsTitle, [], dialogData, paramData)
end sub

sub reclaimResources()
    m.loadItemsTask.control = TaskControl.STOP
    m.loadItemsTask.content = []

    m.data = CreateObject("roSGNode", "ContentNode")
    m.itemGrid.content = m.data

    m.genreData = CreateObject("roSGNode", "ContentNode")
    m.genreList.content = m.genreData
end sub

sub setSearchBackground(state)
    if not m.voiceBox.hasField("textColor") or not m.voiceBox.hasField("hintTextColor") then return

    if state = SearchButtonState.ACTIVE
        if m.searchButtonDisabled
            m.voiceBox.textColor = ColorPalette.MIDGREY
            m.voiceBox.hintTextColor = ColorPalette.MIDGREY
            m.voiceBoxBackground.blendColor = ColorPalette.DARKGREY
            return
        end if

        m.voiceBox.textColor = ColorPalette.WHITE
        m.voiceBox.hintTextColor = ColorPalette.WHITE
        m.voiceBoxBackground.blendColor = chainLookupReturn(m.global.session, "user.settings.colorCursor", ColorPalette.HIGHLIGHT)
        return
    end if

    if state = SearchButtonState.DISABLED
        m.voiceBox.textColor = ColorPalette.DARKGREY
        m.voiceBox.hintTextColor = ColorPalette.DARKGREY
        m.voiceBoxBackground.blendColor = ColorPalette.MIDGREY
        return
    end if

    m.voiceBox.textColor = ColorPalette.MIDGREY
    m.voiceBox.hintTextColor = ColorPalette.MIDGREY
    m.voiceBoxBackground.blendColor = ColorPalette.WHITE
end sub

sub disableSearch(disabledReason as string)
    m.disabledReason = disabledReason
    m.searchButtonDisabled = true
    if m.voiceBox.hasField("voiceEnabled") then m.voiceBox.voiceEnabled = false
    if m.voiceBox.hasField("hintText") then m.voiceBox.hintText = "Search Unavailable"
    setSearchBackground(SearchButtonState.DISABLED)
end sub

sub createFullOverviewDialog()
    if not isValid(m.selectedItemOverview) then return
    if not isValidAndNotEmpty(m.selectedItemOverview.text) then return

    titleText = chainLookupReturn(m.selectedItem, "title", chainLookupReturn(m.selectedItem, "json.Name", tr("Plot")))

    m.global.sceneManager.callFunc("standardDialog", titleText, { data: ["<p>" + m.selectedItemOverview.text + "</p>"] })
end sub


