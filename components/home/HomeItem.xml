<?xml version="1.0" encoding="utf-8"?>
<component name="HomeItem" extends="Group">
  <children>
    <!-- WARNING: DO NOT REMOVE THIS Group OR ITS [6, 6] TRANSLATION. 
         This provides the "Safe Zone" padding for focus highlights to prevent Roku clipping. 
         See UI_ARCHITECTURE.md for details. -->
    <Group translation="[6, 6]">
      <!-- Subtle shadow behind the poster -->
      <Poster id="itemShadow" width="464" height="261" uri="pkg:/images/9patch/filled-rounded.9.png" blendcolor="#020B2A" opacity="0" />

      <Group id="posterGroup">
        <Poster id="focusOutline" uri="pkg:/images/9patch/border-6px.9.png" blendColor="#A64DFF" opacity="0" />
        <Poster id="backdrop" width="464" height="261" loadDisplayMode="scaleToZoom" uri="pkg:/images/white.9.png" visible="false" />
        <Poster id="itemPoster" width="464" height="261" loadDisplayMode="scaleToZoom" />
        <PlayedCheckmark id="playedIndicator" translation="[375, 0]" />
        <Poster id="itemIcon" width="100" height="100" translation="[190,85]" loadDisplayMode="scaleToFit" />

        <Rectangle id="progressBackground" visible="false" width="464" height="8" translation="[0,253]">
          <Rectangle id="progress" width="0" height="8" />
        </Rectangle>
        <Label id="overlaidTitle" width="464" height="261" horizAlign="center" vertAlign="center" wrap="true" font="font:MediumBoldSystemFont" color="#FFFFFF" opacity="1" visible="false" />
      </Group>

      <ScrollingText id="itemText" horizAlign="center" vertAlign="center" font="font:SmallBoldSystemFont" height="64" maxWidth="456" translation="[8,267]" repeatCount="0" />
      <Text id="itemTextExtra" horizAlign="left" vertAlign="center" font="font:SmallBoldSystemFont" height="32" width="456" translation="[8,300]" visible="false" />

      <Animation id="showProgressBar" duration="0.5" repeat="false" easeFunction="linear">
        <FloatFieldInterpolator id="showProgressBarField" key="[0.0, 1.0]" fieldToInterp="progress.width" />
      </Animation>

      <!-- Shadow and focus animation -->
      <Animation id="focusAnimation" duration="0.2" repeat="false" easeFunction="linear">
        <FloatFieldInterpolator id="shadowOpacityInterpolator" key="[0.0, 1.0]" keyValue="[0.0, 0.6]" fieldToInterp="itemShadow.opacity" />
        <FloatFieldInterpolator id="focusOutlineOpacityInterpolator" key="[0.0, 1.0]" keyValue="[0.0, 1.0]" fieldToInterp="focusOutline.opacity" />
      </Animation>
    </Group>
  </children>

  <interface>
    <field id="width" type="float" value="0" onChange="onWidthChanged" />
    <field id="height" type="float" value="0" onChange="onHeightChanged" />
    <field id="itemContent" type="node" onChange="itemContentChanged" />
    <field id="itemHasFocus" type="boolean" onChange="focusChanged" />
    <field id="focusPercent" type="float" onChange="onFocusPercentChange" />
  </interface>

</component>
