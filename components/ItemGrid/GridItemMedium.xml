<?xml version="1.0" encoding="utf-8"?>
<component name="GridItemMedium" extends="Group">
  <children>
    <Group translation="[6, 6]">
      <!-- Subtle shadow behind the poster -->
      <Poster id="itemShadow" translation="[0,0]" uri="pkg:/images/9patch/filled-rounded.9.png" blendcolor="0x000000FF" opacity="0" />

      <Group id="posterGroup" translation="[0,0]">
        <Poster id="focusOutline" uri="pkg:/images/9patch/border-6px.9.png" blendColor="#A64DFF" opacity="0" />
        <Poster id="backdrop" translation="[0,0]" width="400" height="260" loadDisplayMode="scaleToZoom" uri="pkg:/images/white.9.png" visible="false" />
        <Poster id="itemPoster" translation="[0,0]" width="400" height="260" loadDisplayMode="scaleToZoom" />
        <Rectangle id="itemIconBackground" height="60" width="60" translation="[345,225]">
          <Poster id="itemIcon" width="50" height="50" translation="[5,5]" />
        </Rectangle>
        <Text id="posterText" width="400" height="300" translation="[5,5]" horizAlign="center" vertAlign="center" ellipsizeOnBoundary="true" wrap="true" />
        <PlayedCheckmark id="playedIndicator" translation="[340, 22]" />
      </Group>

      <Label id="title" horizAlign="left" vertAlign="bottom" font="font:SmallBoldSystemFont" height="34" />
      <Label id="itemTextExtra" horizAlign="left" vertAlign="center" font="font:SmallBoldSystemFont" height="32" color="#777777FF" />

      <!-- Shadow and focus animation -->
      <Animation id="focusAnimation" duration="0.2" repeat="false" easeFunction="linear">
        <Vector2DFieldInterpolator id="translationInterpolator" key="[0.0, 1.0]" keyValue="[[0, 0], [0, 0]]" fieldToInterp="posterGroup.translation" />
        <FloatFieldInterpolator id="shadowOpacityInterpolator" key="[0.0, 1.0]" keyValue="[0.0, 0.6]" fieldToInterp="itemShadow.opacity" />
        <Vector2DFieldInterpolator id="shadowTranslationInterpolator" key="[0.0, 1.0]" keyValue="[[0, 0], [0, 0]]" fieldToInterp="itemShadow.translation" />
      </Animation>
    </Group>
  </children>
  <interface>
    <field id="height" type="float" value="0" onChange="onHeightChanged" />
    <field id="width" type="float" value="0" onChange="onWidthChanged" />
    <field id="itemContent" type="node" onChange="itemContentChanged" />
    <field id="itemHasFocus" type="boolean" onChange="focusChanged" alwaysNotify="true" />
    <field id="focusPercent" type="float" onChange="onFocusPercentChange" />
  </interface>

</component>