<?xml version="1.0" encoding="utf-8"?>
<component name="GridItemSmall" extends="Group">
  <children>
    <Group translation="[6, 6]">
      <!-- Subtle shadow behind the poster -->
      <Poster id="itemShadow" translation="[0,0]" uri="pkg:/images/9patch/filled-rounded.9.png" blendcolor="0x000000FF" opacity="0" />

      <Group id="posterGroup" translation="[0,0]">
        <Poster id="focusOutline" uri="pkg:/images/9patch/border-6px.9.png" blendColor="#A64DFF" opacity="0" />
        <Poster id="backdrop" loadDisplayMode="scaleToZoom" uri="pkg:/images/white.9.png" visible="false" />
        <Poster id="itemPoster" loadDisplayMode="scaleToZoom" />

        <Group id="gridGroup" visible="false">
          <Poster id="grid1" width="100" height="150" translation="[0, 0]" loadDisplayMode="scaleToZoom" />
          <Poster id="grid2" width="100" height="150" translation="[100, 0]" loadDisplayMode="scaleToZoom" />
          <Poster id="grid3" width="100" height="150" translation="[0, 150]" loadDisplayMode="scaleToZoom" />
          <Poster id="grid4" width="100" height="150" translation="[100, 150]" loadDisplayMode="scaleToZoom" />
        </Group>

        <Poster id="itemIcon" width="50" height="50" visible="false" />
        <Text id="posterText" translation="[5,5]" horizAlign="center" vertAlign="center" ellipsizeOnBoundary="true" wrap="true" color="0xFFFFFFFF" />
        <PlayedCheckmark id="playedIndicator" width="60" height="46" />
      </Group>

      <!-- titleLabel: 2-line wrap, shown when unfocused -->
      <Label id="titleLabel" horizAlign="center" vertAlign="top" font="font:SmallSystemFont" wrap="true" numLines="2" ellipsizeOnBoundary="true" color="0xFFFFFFFF" />

      <!-- Shadow and focus animation -->
      <Animation id="focusAnimation" duration="0.2" repeat="false" easeFunction="linear">
        <Vector2DFieldInterpolator id="translationInterpolator" key="[0.0, 1.0]" keyValue="[[0, 0], [0, 0]]" fieldToInterp="posterGroup.translation" />
        <FloatFieldInterpolator id="shadowOpacityInterpolator" key="[0.0, 1.0]" keyValue="[0.0, 0.6]" fieldToInterp="itemShadow.opacity" />
        <Vector2DFieldInterpolator id="shadowTranslationInterpolator" key="[0.0, 1.0]" keyValue="[[0, 0], [0, 0]]" fieldToInterp="itemShadow.translation" />
      </Animation>
    </Group>
  </children>

  <interface>
    <field id="height" type="float" value="0" onChange="onHeightChanged" />
    <field id="width" type="float" value="0" onChange="onWidthChanged" />
    <field id="itemContent" type="node" onChange="itemContentChanged" alwaysNotify="true" />
    <field id="itemHasFocus" type="boolean" onChange="focusChanged" alwaysNotify="true" />
    <field id="focusPercent" type="float" onChange="onFocusPercentChange" />
  </interface>
</component>