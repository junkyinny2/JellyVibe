<?xml version="1.0" encoding="utf-8"?>
<component name="StreamDropdownItem" extends="Group">
  <script type="text/brightscript" uri="StreamDropdownItem.bs" />
  <interface>
    <field id="itemContent" type="node" />
    <field id="focusPercent" type="float" />
    <field id="itemHasFocus" type="boolean" />
    <field id="index" type="integer" />
    <field id="width" type="float" />
    <field id="height" type="float" />
  </interface>

  <children>
    <Poster id="bg" uri="pkg:/images/9patch/filled-rounded.9.png" blendColor="#1e1e26" />
    <Poster id="check" width="16" height="16" translation="[16, 18]" uri="pkg:/images/icons/check_white.png" blendColor="#ffffff" visible="false" />
    <Text id="title" font="font:SmallestSystemFont" color="#e8e8ee" translation="[48, 4]" maxLines="1" width="260" height="18" />
    <Text id="subtitle" font="font:SmallestSystemFont" color="#999999" translation="[48, 26]" maxLines="1" width="260" height="18" visible="true" />
  </children>
</component>
