<?xml version="1.0" encoding="utf-8"?>
<component name="MovieOptions" extends="Group">
  <children>
    <Rectangle width="1920" height="1080" color="#020B2A" opacity="0.6" />
    <Group id="popupGroup" translation="[460, 150]"> <!-- Positioned center-right by default -->
      <Poster id="background" width="1000" height="780" uri="pkg:/images/dialog.9.png" />
      <LayoutGroup horizAlignment="center" translation="[500, 50]" itemSpacings="[40]">
        <JFButtons id="buttons" />
        <Group>
          <RadiobuttonList id="subtitleMenu" itemspacing="[0,10]" opacity="1" vertFocusAnimationStyle="floatingFocus" drawFocusFeedback="false" itemSize="[900, 70]" numRows="8" />
          <RadiobuttonList id="audioMenu" itemspacing="[0,10]" opacity="0" vertFocusAnimationStyle="floatingFocus" drawFocusFeedback="false" itemSize="[900, 70]" numRows="8" />
          <RadiobuttonList id="videoMenu" itemspacing="[0,10]" opacity="0" vertFocusAnimationStyle="floatingFocus" drawFocusFeedback="false" itemSize="[900, 100]" numRows="6" />
          <RadiobuttonList id="optionMenu" itemspacing="[0,10]" opacity="0" vertFocusAnimationStyle="floatingFocus" drawFocusFeedback="false" itemSize="[900, 70]" numRows="8">
            <ContentNode role="content">
              <ContentNode title="Play Normally" id="playNormally" />
              <ContentNode title="Force Transcode (Allow Remux)" id="forceTranscodeAllowRemux" />
              <ContentNode title="Force Transcode (Remux Disabled)" id="forceTranscodeDisableRemux" />
            </ContentNode>
          </RadiobuttonList>
        </Group>
      </LayoutGroup>
    </Group>

    <Animation id="fadeAnim" duration="0.5" repeat="false">
      <FloatFieldInterpolator id="outOpacity" key="[0.0, 0.5, 1.0]" keyValue="[ 1, 0, 0 ]" fieldToInterp="focus.opacity" />
      <FloatFieldInterpolator id="inOpacity" key="[0.0, 0.5, 1.0]" keyValue="[ 0, 0, 1 ]" fieldToInterp="focus.opacity" />
    </Animation>

  </children>
  <interface>
    <function name="showVideoMenu" />
    <function name="showAudioMenu" />
    <function name="showSubtitleMenu" />
    <field id="buttons" type="nodearray" />
    <field id="options" type="assocarray" onChange="optionsSet" />
    <field id="videoStreamId" type="string" />
    <field id="video_codec" type="string" />
    <field id="codec" type="string" />
    <field id="audioStreamIndex" type="integer" />
    <field id="audioStreamName" type="string" />
    <field id="subtitleStream" type="node" />
  </interface>

</component>