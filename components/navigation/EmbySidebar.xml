<?xml version="1.0" encoding="utf-8"?>
<component name="EmbySidebar" extends="Group" focusable="true">
  <children>
    <!-- Frosted background -->
    <Rectangle id="background" width="300" height="1080" color="#0D0D0D" opacity="0.92" />

    <!-- Navigation Items Group -->
    <LayoutGroup id="menuGroup" layoutDirection="vert" translation="[0, 120]" itemSpacings="[8]">
      <Label id="navHome" text="Home" font="font:MediumBoldSystemFont" color="#FFFFFF" width="300" height="60" horizAlign="left" translation="[24, 0]" />
      <Label id="navMovies" text="Movies" font="font:MediumBoldSystemFont" color="#AAAAAA" width="300" height="60" horizAlign="left" translation="[24, 0]" />
      <Label id="navTV" text="TV Shows" font="font:MediumBoldSystemFont" color="#AAAAAA" width="300" height="60" horizAlign="left" translation="[24, 0]" />
      <Label id="navMusic" text="Music" font="font:MediumBoldSystemFont" color="#AAAAAA" width="300" height="60" horizAlign="left" translation="[24, 0]" />
      <Label id="navSettings" text="Settings" font="font:MediumBoldSystemFont" color="#AAAAAA" width="300" height="60" horizAlign="left" translation="[24, 0]" />
    </LayoutGroup>

    <!-- Focus Highlight Bar -->
    <Rectangle id="focusHighlight" width="4" height="60" color="#AA5CC3" opacity="0" translation="[0, 120]" />
  </children>

  <interface>
    <field id="expanded" type="boolean" value="false" onChange="onExpandedChange" />
    <function name="clearFocusHighlight" />
  </interface>
</component>