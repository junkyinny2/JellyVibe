{
  "name": "jellyvibe",
  "type": "module",
  "version": "1.2.4",
  "description": "Official Roku app for Jellyvibe media server",
  "dependencies": {
    "@rokucommunity/bslib": "0.1.1",
    "brighterscript-formatter": "1.7.19"
  },
  "devDependencies": {
    "@rokucommunity/bslint": "0.8.38",
    "brighterscript": "0.70.3",
    "jshint": "2.13.6",
    "rimraf": "^6.1.3",
    "roku-deploy": "^3.16.1",
    "undent": "1.0.0"
  },
  "scripts": {
    "build": "npx rimraf build/ out/ && npx bsc --project bsconfig.json",
    "build:deploy": "npx rimraf build/ out/ && npx bsc --project bsconfig.deploy.json",
    "deploy": "npx rimraf build/ out/ && npx bsc --project bsconfig.deploy.json --deploy",
    "docs:update-diff": "node scripts/update-diff-docs.mjs",
    "pages:build": "node scripts/build-pages-site.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jellyfin/jellyfin-roku.git"
  },
  "keywords": [
    "jellyfin",
    "roku",
    "music",
    "movies"
  ],
  "author": "Jellyfin",
  "license": "GPL-2.0",
  "bugs": {
    "url": "https://github.com/jellyfin/jellyfin-roku"
  },
  "homepage": "https://github.com/jellyfin/jellyfin-roku"
}